---
const year = new Date().getFullYear();
---

<section class="contact-section" aria-label="Kontakt">
  <div class="contact-inner">
    <div class="contact-label">Kontakt</div>
    <div class="contact-links">
      <a href="mailto:mail@karstenuhlig.de">
        mail@karstenuhlig.de<span class="arrow" aria-hidden="true">→</span>
      </a>
      <a
        href="https://www.linkedin.com/in/karsten-uhlig/"
        target="_blank"
        rel="noopener"
      >
        LinkedIn<span class="arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-name">Karsten Uhlig</div>
    <nav class="footer-links" aria-label="Footer-Navigation">
      <a href="/">Startseite</a>
      <a href="/impressum">Impressum</a>
      <a href="/datenschutz">Datenschutz</a>
    </nav>
    <div class="footer-copyright">© {year} Karsten Uhlig</div>
  </div>
</footer>

<style>
  /* --- Kontakt-Sektion: eigener Bereich ueber der Footer-Leiste --- */
  .contact-section {
    border-top: 1px solid var(--color-border);
    margin-top: 2rem;
  }
  .contact-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 4rem;
  }
  .contact-label {
    font-size: 12px;
    color: var(--color-amber);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 500;
    margin-bottom: 1.25rem;
  }
  .contact-links {
    display: flex;
    gap: 3.5rem;
    font-size: 18px;
  }
  .contact-links a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-ink);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .contact-links a:hover {
    color: var(--color-ink-2);
  }
  .contact-links .arrow {
    color: var(--color-amber);
    transition: transform 0.2s ease;
  }
  .contact-links a:hover .arrow {
    transform: translateX(3px);
  }

  /* --- Footer-Leiste: separater Streifen, gedaempft und kleiner --- */
  .footer {
    border-top: 1px solid var(--color-border);
  }
  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 4rem;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 2rem;
    font-size: 13px;
    color: var(--color-ink-3);
  }
  .footer-name {
    justify-self: start;
    font-weight: 500;
    color: var(--color-ink-2);
  }
  .footer-links {
    display: flex;
    gap: 1.75rem;
    justify-self: center;
  }
  .footer-links a {
    color: var(--color-ink-2);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .footer-links a:hover {
    color: var(--color-ink);
  }
  .footer-copyright {
    justify-self: end;
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .contact-inner {
      padding: 3rem 1.5rem;
      text-align: center;
    }
    .contact-links {
      justify-content: center;
      gap: 2.5rem;
    }
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 1rem;
      padding: 2rem 1.5rem;
      text-align: center;
    }
    .footer-name,
    .footer-links,
    .footer-copyright {
      justify-self: center;
    }
  }
</style>
