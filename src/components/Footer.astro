---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-contact">
    <div class="footer-contact-label">Kontakt</div>
    <div class="footer-contact-links">
      <a href="mailto:mail@karstenuhlig.de">mail@karstenuhlig.de</a>
      <a
        href="https://www.linkedin.com/in/karsten-uhlig/"
        target="_blank"
        rel="noopener"
      >
        LinkedIn
      </a>
    </div>
  </div>
  <div class="footer-inner">
    <nav class="footer-links" aria-label="Footer-Navigation">
      <a href="/impressum">Impressum</a>
      <a href="/datenschutz">Datenschutz</a>
    </nav>
    <div class="footer-copyright">© {year} Karsten Uhlig</div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    margin-top: 2rem;
  }
  .footer-contact {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2.5rem 4rem 0.5rem;
  }
  .footer-contact-label {
    font-size: 11px;
    color: var(--color-ink-3);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 500;
    margin-bottom: 0.875rem;
  }
  .footer-contact-links {
    display: flex;
    gap: 1.75rem;
    font-size: 14px;
  }
  .footer-contact-links a {
    color: var(--color-ink-2);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .footer-contact-links a:hover {
    color: var(--color-ink);
  }
  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1.25rem 4rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    font-size: 12px;
    color: var(--color-ink-3);
  }
  .footer-links {
    display: flex;
    gap: 1.5rem;
  }
  .footer-links a {
    color: var(--color-ink-3);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .footer-links a:hover {
    color: var(--color-ink-2);
  }
  .footer-copyright {
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .footer-contact {
      padding: 2.5rem 1.5rem 0.5rem;
      text-align: center;
    }
    .footer-contact-links {
      justify-content: center;
    }
    .footer-inner {
      flex-direction: column;
      gap: 1rem;
      padding: 1.25rem 1.5rem 2rem;
      justify-content: center;
      text-align: center;
    }
    .footer-links {
      justify-content: center;
    }
  }
</style>
