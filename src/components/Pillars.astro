---
const pillars = [
  {
    href: "/e-commerce-marketing",
    title: "E-Commerce & Marketing",
    desc: "Wo das Geschäftsergebnis entsteht. Wachstum, Conversion, Kanäle und internationale Märkte, aus 25 Jahren als Operator.",
  },
  {
    href: "/martech",
    title: "MarTech",
    desc: "Die Schicht darunter, die das Ergebnis trägt. Datenarchitektur, Operating Model und Anwendungen, die produktiv laufen.",
  },
  {
    href: "/agentic-ai",
    title: "Agentic AI",
    desc: "Der vorderste Hebel. Markt-These zur Implementierungs-Welle und sem-agentic, ein selbst entwickeltes agentisches System für Search-Engine-Marketing.",
  },
];
---

<section class="pillars-section">
  <div class="pillars-eyebrow">Meine Schwerpunkte</div>
  <div class="pillars">
    {
      pillars.map(({ href, title, desc }) => (
        <a href={href} class="pillar">
          <span class="hair hair-1" aria-hidden="true" />
          <span class="hair hair-2" aria-hidden="true" />
          <div class="pillar-title">{title}</div>
          <div class="pillar-desc">{desc}</div>
          <div class="pillar-meta">Übersicht →</div>
        </a>
      ))
    }
  </div>
</section>

<style>
  .pillars-section {
    position: relative;
    padding-top: 1rem;
  }
  .pillars-eyebrow {
    font-size: 11px;
    color: var(--color-ink-3);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    font-weight: 500;
  }
  .pillars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .pillar {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    background: linear-gradient(
      180deg,
      rgba(164, 192, 217, 0.55) 0%,
      rgba(214, 228, 239, 0.42) 45%,
      rgba(246, 249, 252, 0.55) 100%
    );
    border: 1px solid var(--color-border-soft);
    border-radius: 3px;
    padding: 2rem 1.75rem;
    cursor: pointer;
    transition:
      border-color 0.2s ease,
      transform 0.2s ease;
    text-decoration: none;
    display: block;
  }
  /* HairCard: zwei sehr helle 18deg-Hairlines hinter dem Text */
  .pillar .hair {
    position: absolute;
    width: 1px;
    transform: rotate(18deg);
    transform-origin: top center;
    z-index: -1;
    pointer-events: none;
  }
  .pillar .hair-1 {
    top: -30px;
    right: 46px;
    height: 230px;
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(30, 60, 100, 0.09) 32%,
      rgba(30, 60, 100, 0.02) 75%,
      transparent 100%
    );
  }
  .pillar .hair-2 {
    top: 8px;
    right: 90px;
    height: 170px;
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(30, 60, 100, 0.05) 35%,
      rgba(30, 60, 100, 0.015) 75%,
      transparent 100%
    );
  }
  .pillar:hover {
    border-color: rgba(180, 83, 9, 0.45);
    transform: translateY(-2px);
  }
  .pillar-title {
    font-size: 22px;
    font-weight: 500;
    color: var(--color-ink);
    letter-spacing: -0.015em;
    margin-bottom: 0.75rem;
  }
  .pillar-desc {
    font-size: 14px;
    line-height: 1.6;
    color: var(--color-ink-2);
    margin-bottom: 1.25rem;
  }
  .pillar-meta {
    font-size: 11px;
    color: var(--color-amber);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .pillars {
      grid-template-columns: 1fr;
    }
  }
</style>
