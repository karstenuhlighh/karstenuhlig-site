---
const pillars = [
  {
    href: "/e-commerce-marketing",
    title: "E-Commerce & Marketing",
    desc: "Wo das Geschäftsergebnis entsteht. Wachstum, Conversion, Kanäle und internationale Märkte, aus 25 Jahren als Operator.",
  },
  {
    href: "/martech",
    title: "MarTech",
    desc: "Die Schicht darunter, die das Ergebnis trägt. Datenarchitektur, Operating Model und Anwendungen, die produktiv laufen.",
  },
  {
    href: "/agentic-ai",
    title: "Agentic AI",
    desc: "Die Implementierungs-Welle, praktisch geprüft. Markt-These plus sem-agentic, ein eigener Engineering-Prototyp für Search-Engine-Marketing.",
  },
];
---

<section class="pillars-section">
  <div class="pillars-eyebrow">Meine Schwerpunkte</div>
  <div class="pillars">
    {
      pillars.map(({ href, title, desc }) => (
        <a href={href} class="pillar">
          <span class="hair hair-1" aria-hidden="true" />
          <span class="hair hair-2" aria-hidden="true" />
          <div class="pillar-title">{title}</div>
          <div class="pillar-desc">{desc}</div>
          <div class="pillar-meta">Übersicht →</div>
        </a>
      ))
    }
  </div>
</section>

<style>
  .pillars-section {
    position: relative;
    padding-top: 4rem;
  }
  .pillars-eyebrow {
    font-size: 11px;
    color: var(--color-ink-3);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    font-weight: 500;
  }
  .pillars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .pillar {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.54);
    border: 1px solid rgba(30, 60, 100, 0.12);
    border-top: 3px solid rgba(30, 60, 100, 0.22);
    border-radius: 2px;
    padding: 2.15rem 1.8rem 1.75rem;
    cursor: pointer;
    transition:
      border-color 0.2s ease,
      background 0.2s ease,
      box-shadow 0.2s ease,
      transform 0.2s ease;
    text-decoration: none;
    display: block;
  }
  /* Hairlines bleiben auf der Startseite dem Hero vorbehalten. */
  .pillar .hair {
    display: none;
  }
  .pillar .hair-1 {
    top: -30px;
    right: 46px;
    height: 230px;
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(30, 60, 100, 0.09) 32%,
      rgba(30, 60, 100, 0.02) 75%,
      transparent 100%
    );
  }
  .pillar .hair-2 {
    top: 8px;
    right: 90px;
    height: 170px;
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(30, 60, 100, 0.05) 35%,
      rgba(30, 60, 100, 0.015) 75%,
      transparent 100%
    );
  }
  .pillar:hover {
    background: rgba(255, 255, 255, 0.74);
    border-color: rgba(30, 60, 100, 0.18);
    border-top-color: rgba(180, 83, 9, 0.65);
    box-shadow: 0 10px 24px rgba(30, 60, 100, 0.06);
    transform: translateY(-2px);
  }
  .pillar-title {
    font-size: 22px;
    font-weight: 500;
    color: var(--color-ink);
    letter-spacing: -0.015em;
    margin-bottom: 0.75rem;
  }
  .pillar-desc {
    font-size: 14px;
    line-height: 1.6;
    color: var(--color-ink-2);
    margin-bottom: 1.25rem;
  }
  .pillar-meta {
    font-size: 11px;
    color: var(--color-amber);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .pillars {
      grid-template-columns: 1fr;
    }
  }
</style>
