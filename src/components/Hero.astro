---
import Nav from "./Nav.astro";
import SemAgenticTeaser from "./SemAgenticTeaser.astro";
---

<section class="hero">
  <div class="diag-line-1"></div>
  <div class="diag-line-2"></div>
  <div class="hero-inner">
    <Nav />
    <div class="hero-grid">
      <div class="eyebrow">Senior Digital Executive</div>
      <h1 class="headline">Closing the<br />Implementation Gap.</h1>
      <p class="subtitle">
        Commerce &amp; Marketing Outcomes through MarTech, Data &amp; AI.
      </p>
      <div class="ueber-mich-marker">
        <div class="ueber-mich-eyebrow">Über mich</div>
      </div>
      <div class="portrait">
        <div class="portrait-backdrop" aria-hidden="true"></div>
        <img
          src="/portrait-freigestellt.png"
          alt="Portrait Karsten Uhlig"
          width="800"
          height="1000"
        />
      </div>
      <div class="bio">
        <p>
          Als Digital Executive habe ich in der Otto Group das
          Online-Geschäft von bonprix in 20+ Ländern auf über 1,6 Mrd. €
          Umsatz skaliert und dabei 120+ Mitarbeitende in 25 Teams
          geführt — mit über 20 Jahren Erfahrung in E-Commerce, Marketing
          und digitaler Transformation.
        </p>
        <p>
          Mein roter Faden ist das Schließen der Lücke zwischen
          strategischer Einsicht und tatsächlicher Umsetzung —
          organisatorisch wie technisch. Genau diese Stärke baue ich 2026
          gezielt im Bereich Agentic AI aus: nicht als Beobachter, sondern
          in der praktischen Umsetzung, um die nächste Transformation in
          digitalem Business und Marketing mitzugestalten.
        </p>
      </div>
    </div>
    <div class="teaser-area">
      <SemAgenticTeaser />
    </div>
    <slot />
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    overflow: hidden;
  }
  .hero::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 320px;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.18) 0%,
      rgba(220, 235, 250, 0.06) 60%,
      transparent 100%
    );
    pointer-events: none;
  }
  .hero-inner {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 4rem 0; /* pb: 0 -- Portrait sitzt am Section-Bottom */
  }
  .diag-line-1 {
    position: absolute;
    top: 60px;
    right: 4%;
    width: 1px;
    height: 620px;
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(30, 60, 100, 0.3) 25%,
      rgba(30, 60, 100, 0.1) 65%,
      transparent 100%
    );
    transform: rotate(18deg);
    transform-origin: top right;
    pointer-events: none;
  }
  .diag-line-2 {
    position: absolute;
    top: 140px;
    right: 10%;
    width: 1px;
    height: 420px;
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(30, 60, 100, 0.18) 40%,
      transparent 100%
    );
    transform: rotate(18deg);
    transform-origin: top right;
    pointer-events: none;
  }

  /* --- DESKTOP --- Grid mit Named Areas --- */
  /* Portrait linke Spalte, Text-Block rechte Spalte.
     teaser ist nicht mehr im Grid (haengt darunter, full-width), damit
     das Portrait am unteren Hero-Sektionsrand angeschnitten sitzen kann. */
  .hero-grid {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    grid-template-areas:
      "portrait eyebrow"
      "portrait headline"
      "portrait subtitle"
      "portrait ueber-mich"
      "portrait bio";
    column-gap: 4rem;
    row-gap: 0;
    align-items: start;
    margin-bottom: 0;
  }
  .ueber-mich-marker {
    grid-area: ueber-mich;
    padding-top: 2rem;
    margin-top: 0.5rem;
    margin-bottom: 1.5rem;
    border-top: 1px solid var(--color-border);
  }
  .ueber-mich-eyebrow {
    font-size: 12px;
    color: var(--color-amber);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 500;
  }
  .eyebrow {
    grid-area: eyebrow;
    font-size: 12px;
    color: var(--color-amber);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    font-weight: 500;
  }
  .headline {
    grid-area: headline;
    font-size: 56px;
    font-weight: 500;
    line-height: 1.02;
    letter-spacing: -0.035em;
    margin-bottom: 1.5rem;
    color: var(--color-ink);
  }
  .subtitle {
    grid-area: subtitle;
    font-size: 17px;
    color: var(--color-ink-2);
    margin-bottom: 2.5rem;
    max-width: 520px;
  }
  .bio {
    grid-area: bio;
    max-width: 580px;
  }
  .bio p {
    font-size: 15px;
    line-height: 1.75;
    color: var(--color-body);
    margin: 0;
  }
  .bio p + p {
    margin-top: 1rem;
  }
  /* Foto-Brief v2 (Komposition 1+2):
     - Figur bottom-anchored, deutlich groesser als v1, leicht
       nach links versetzt (Mittelpunkt ~40% der Spalte)
     - Slate-Backdrop hinter Figur: blutet links + unten ueber
       Sektionskante aus (overflow:hidden auf .hero clippt sauber),
       obere Kante gerade auf Schulter-/Brusthoehe -> Kopf ragt
       ueber Backdrop ins Hellblau (Tiefen-Effekt) */
  .portrait {
    grid-area: portrait;
    align-self: end;
    position: relative;
    width: 100%;
  }
  .portrait-backdrop {
    position: absolute;
    left: -100vw; /* bleed bis ans Viewport-Ende links */
    right: -5%; /* endet knapp hinter Figurbreite */
    top: 42%; /* obere Kante auf Schulter-/Brusthoehe */
    bottom: -3rem; /* bleed unten ueber Sektionskante */
    background: #2f4256;
    z-index: 1;
  }
  .portrait img {
    position: relative;
    z-index: 2; /* Figur ueber Backdrop */
    display: block;
    width: 120%;
    height: auto;
    margin-left: -15%; /* Figur etwas nach links versetzt */
  }
  .teaser-area {
    margin-top: 4rem;
    padding-bottom: 5rem;
  }

  /* --- MOBILE --- Foto ganz oben (ueber der Headline), gestapelt --- */
  @media (max-width: 768px) {
    .hero-inner {
      padding: 2rem 1.5rem 0;
    }
    .hero-grid {
      display: flex;
      flex-direction: column;
      gap: 0;
      margin-bottom: 0;
    }
    .portrait {
      order: 1;
      max-width: 100%;
      width: 100%;
      margin: 0 0 1.5rem;
      position: relative;
    }
    .portrait-backdrop {
      /* Vollbreites Band hinter der Figur (bleed bis Section-Rand) */
      left: -1.5rem;
      right: -1.5rem;
      top: 38%;
      bottom: -2rem;
    }
    .portrait img {
      width: 75%;
      max-width: 320px;
      margin-left: auto;
      margin-right: auto;
    }
    .eyebrow {
      order: 2;
      margin-bottom: 0.75rem;
    }
    .headline {
      order: 3;
      font-size: 32px;
      margin-bottom: 1rem;
    }
    .subtitle {
      order: 4;
      margin-bottom: 0;
    }
    .ueber-mich-marker {
      order: 5;
      margin-top: 2.5rem;
      padding-top: 2rem;
      margin-bottom: 0;
      border-top: 1px solid var(--color-border);
    }
    .bio {
      order: 6;
      margin-top: 2rem;
    }
    .teaser-area {
      margin-top: 2rem;
      padding-bottom: 3rem;
    }
  }
</style>
