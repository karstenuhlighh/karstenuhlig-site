---
import Nav from "./Nav.astro";
import SemAgenticTeaser from "./SemAgenticTeaser.astro";
---

<section class="hero">
  <div class="diag-line-1"></div>
  <div class="diag-line-2"></div>
  <div class="hero-inner">
    <Nav />
    <div class="hero-grid">
      <div class="eyebrow">Senior Digital Executive</div>
      <h1 class="headline">Closing the<br />Implementation Gap.</h1>
      <p class="subtitle">
        Commerce &amp; Marketing Outcomes through MarTech, Data &amp; AI.
      </p>
      <div class="ueber-mich-marker">
        <div class="ueber-mich-eyebrow">Über mich</div>
      </div>
      <div class="portrait">
        <img
          src="/portrait-freigestellt.png"
          alt="Portrait Karsten Uhlig"
          width="800"
          height="1000"
        />
      </div>
      <div class="bio">
        <p>
          Als Digital Executive habe ich in der Otto Group das
          Online-Geschäft von bonprix in 20+ Ländern auf über 1,6 Mrd. €
          Umsatz skaliert und dabei 120+ Mitarbeitende in 25 Teams
          geführt — mit über 20 Jahren Erfahrung in E-Commerce, Marketing
          und digitaler Transformation.
        </p>
        <p>
          Mein roter Faden ist das Schließen der Lücke zwischen
          strategischer Einsicht und tatsächlicher Umsetzung —
          organisatorisch wie technisch. Genau diese Stärke baue ich 2026
          gezielt im Bereich Agentic AI aus: nicht als Beobachter, sondern
          in der praktischen Umsetzung, um die nächste Transformation in
          digitalem Business und Marketing mitzugestalten.
        </p>
      </div>
      <div class="teaser-area">
        <SemAgenticTeaser />
      </div>
    </div>
    <slot />
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    overflow: hidden;
  }
  .hero::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 320px;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.18) 0%,
      rgba(220, 235, 250, 0.06) 60%,
      transparent 100%
    );
    pointer-events: none;
  }
  .hero-inner {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 4rem 5rem;
  }
  .diag-line-1 {
    position: absolute;
    top: 60px;
    right: 4%;
    width: 1px;
    height: 620px;
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(30, 60, 100, 0.3) 25%,
      rgba(30, 60, 100, 0.1) 65%,
      transparent 100%
    );
    transform: rotate(18deg);
    transform-origin: top right;
    pointer-events: none;
  }
  .diag-line-2 {
    position: absolute;
    top: 140px;
    right: 10%;
    width: 1px;
    height: 420px;
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(30, 60, 100, 0.18) 40%,
      transparent 100%
    );
    transform: rotate(18deg);
    transform-origin: top right;
    pointer-events: none;
  }

  /* --- DESKTOP --- Grid mit Named Areas --- */
  /* Portrait jetzt LINKS, Text-Block RECHTS — Bild schaut in den
     Content rein, nicht aus dem Layout heraus. */
  .hero-grid {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    grid-template-areas:
      "portrait eyebrow"
      "portrait headline"
      "portrait subtitle"
      "portrait ueber-mich"
      "portrait bio"
      "teaser   teaser";
    column-gap: 4rem;
    row-gap: 0;
    align-items: start;
    margin-bottom: 5rem;
  }
  .ueber-mich-marker {
    grid-area: ueber-mich;
    padding-top: 2rem;
    margin-top: 0.5rem;
    margin-bottom: 1.5rem;
    border-top: 1px solid var(--color-border);
  }
  .ueber-mich-eyebrow {
    font-size: 12px;
    color: var(--color-amber);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 500;
  }
  .eyebrow {
    grid-area: eyebrow;
    font-size: 12px;
    color: var(--color-amber);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    font-weight: 500;
  }
  .headline {
    grid-area: headline;
    font-size: 56px;
    font-weight: 500;
    line-height: 1.02;
    letter-spacing: -0.035em;
    margin-bottom: 1.5rem;
    color: var(--color-ink);
  }
  .subtitle {
    grid-area: subtitle;
    font-size: 17px;
    color: var(--color-ink-2);
    margin-bottom: 2.5rem;
    max-width: 520px;
  }
  .bio {
    grid-area: bio;
    max-width: 580px;
  }
  .bio p {
    font-size: 15px;
    line-height: 1.75;
    color: var(--color-body);
    margin: 0;
  }
  .bio p + p {
    margin-top: 1rem;
  }
  /* Maximal eingebettet: keine Card, kein Hintergrund, kein Border,
     kein Box-Shadow. Das freigestellte PNG schwebt direkt auf dem
     Sky-Gradient -- die transparenten Bereiche lassen den Verlauf
     nahtlos durchscheinen. */
  .portrait {
    grid-area: portrait;
    align-self: center;
    width: 100%;
  }
  .portrait img {
    display: block;
    width: 100%;
    height: auto;
  }
  .teaser-area {
    grid-area: teaser;
    margin-top: 4rem;
  }

  /* --- MOBILE --- flach gestapelt mit CSS-Order --- */
  @media (max-width: 768px) {
    .hero-inner {
      padding: 2rem 1.5rem 3rem;
    }
    .hero-grid {
      display: flex;
      flex-direction: column;
      gap: 0;
      margin-bottom: 3rem;
    }
    .eyebrow {
      order: 1;
      margin-bottom: 0.75rem;
    }
    .headline {
      order: 2;
      font-size: 32px;
      margin-bottom: 1rem;
    }
    .subtitle {
      order: 3;
      margin-bottom: 0;
    }
    .teaser-area {
      order: 4;
      margin-top: 2rem;
    }
    .ueber-mich-marker {
      order: 5;
      margin-top: 2.5rem;
      padding-top: 2rem;
      margin-bottom: 0;
      border-top: 1px solid var(--color-border);
    }
    .portrait {
      order: 6;
      max-width: 220px;
      margin: 1.5rem auto 0;
    }
    .bio {
      order: 7;
      margin-top: 2rem;
    }
  }
</style>
