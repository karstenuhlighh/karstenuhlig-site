---
import Nav from "./Nav.astro";
import SemAgenticTeaser from "./SemAgenticTeaser.astro";
---

<section class="hero">
  <div class="diag-line-1"></div>
  <div class="diag-line-2"></div>
  <div class="hero-inner">
    <Nav />
    <div class="hero-grid">
      <div class="eyebrow">Senior Digital Executive</div>
      <h1 class="headline">
        <span class="headline-line1">Growing digital commerce.</span><br
        />Closing the gap between strategy and results.
      </h1>
      <p class="subtitle">
        E-Commerce &amp; Marketing Outcomes through MarTech,
        Data&nbsp;&amp;&nbsp;AI.
      </p>
      <div class="cover-proof" aria-label="Kurzprofil">
        <div class="cover-proof-item">
          <span class="cover-proof-value">€1,6+ Mrd</span>
          <span class="cover-proof-label">Online Business skaliert</span>
        </div>
        <div class="cover-proof-item">
          <span class="cover-proof-value">25+ Jahre</span>
          <span class="cover-proof-label">Digital Commerce</span>
        </div>
        <div class="cover-proof-item">
          <span class="cover-proof-value">20+ Märkte</span>
          <span class="cover-proof-label">Digital Commerce Europa</span>
        </div>
      </div>
      <div class="ueber-mich-marker">
        <div class="ueber-mich-eyebrow">Über mich</div>
      </div>
      <div class="portrait">
        <div class="portrait-line-1" aria-hidden="true"></div>
        <div class="portrait-line-2" aria-hidden="true"></div>
        <img
          src="/portrait-freigestellt.png"
          alt="Portrait Karsten Uhlig"
          width="1000"
          height="1250"
        />
      </div>
      <div class="bio">
        <p>
          Als Digital Executive habe ich bei bonprix das Online-Geschäft in
          über 20 Ländern auf mehr als 1,6 Mrd. € Umsatz skaliert. Zuletzt
          habe ich 120 Mitarbeitende in 25 Teams geführt und E-Commerce,
          Marketing, Daten und Technologie gemeinsam verantwortet.
        </p>
        <p>
          Mein roter Faden ist das Schließen der Lücke zwischen
          strategischer Einsicht und tatsächlicher Umsetzung,
          organisatorisch wie technisch. Genau daran arbeite ich jetzt mit
          Agentic AI weiter. Nicht als Beobachter, sondern praktisch: an
          Systemen, die zeigen, wo aus Technologie Wirkung im digitalen
          Geschäft und Marketing entstehen kann.
        </p>
      </div>
    </div>
    <div class="teaser-area">
      <SemAgenticTeaser />
    </div>
    <slot />
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    overflow: hidden;
  }
  .hero::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 320px;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.18) 0%,
      rgba(220, 235, 250, 0.06) 60%,
      transparent 100%
    );
    pointer-events: none;
  }
  .hero-inner {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 4rem 3rem;
  }
  .diag-line-1 {
    position: absolute;
    top: 60px;
    right: 4%;
    width: 1px;
    height: 620px;
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(30, 60, 100, 0.3) 25%,
      rgba(30, 60, 100, 0.1) 65%,
      transparent 100%
    );
    transform: rotate(18deg);
    transform-origin: top right;
    pointer-events: none;
  }
  .diag-line-2 {
    position: absolute;
    top: 140px;
    right: 10%;
    width: 1px;
    height: 420px;
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(30, 60, 100, 0.18) 40%,
      transparent 100%
    );
    transform: rotate(18deg);
    transform-origin: top right;
    pointer-events: none;
  }

  /* --- DESKTOP --- Grid mit Named Areas --- */
  /* Portrait linke Spalte, Text-Block rechte Spalte.
     teaser ist nicht mehr im Grid (haengt darunter, full-width), damit
     das Portrait am unteren Hero-Sektionsrand angeschnitten sitzen kann. */
  .hero-grid {
    position: relative;
    display: grid;
    grid-template-columns: 0.98fr 1.32fr;
    grid-template-areas:
      "portrait eyebrow"
      "portrait headline"
      "portrait subtitle"
      "portrait proof"
      "portrait ueber-mich"
      "portrait bio";
    column-gap: 4.25rem;
    row-gap: 0;
    align-items: start;
    margin-bottom: 0;
    padding-bottom: 4rem;
    border-bottom: 1px solid rgba(30, 60, 100, 0.14);
  }
  .ueber-mich-marker {
    grid-area: ueber-mich;
    padding-top: 2rem;
    margin-top: 0.5rem;
    margin-bottom: 0.75rem;
    border-top: 1px solid var(--color-border);
  }
  .ueber-mich-eyebrow {
    font-size: 12px;
    color: var(--color-ink-3);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 500;
  }
  .eyebrow {
    grid-area: eyebrow;
    font-size: 12px;
    color: var(--color-amber);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
    font-weight: 500;
  }
  .headline {
    grid-area: headline;
    font-size: clamp(44px, 4.55vw, 56px);
    font-weight: 500;
    line-height: 0.99;
    letter-spacing: -0.045em;
    margin-bottom: 1.5rem;
    color: var(--color-ink);
    text-wrap: balance;
    max-width: 760px;
  }
  /* Erste Headline-Zeile nur dort umbruchfrei halten, wo die Spalte breit
     genug ist -- auf schmalen Viewports darf sie weiter umbrechen. */
  @media (min-width: 1024px) {
    .headline-line1 {
      white-space: nowrap;
    }
  }
  .subtitle {
    grid-area: subtitle;
    font-size: 17px;
    color: var(--color-ink-2);
    margin-bottom: 0;
    max-width: 600px;
  }
  .cover-proof {
    grid-area: proof;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.9rem;
    max-width: 680px;
    margin: 1.55rem 0 1.75rem;
    padding: 1.05rem 0 1.15rem;
    border-top: 1px solid rgba(30, 60, 100, 0.16);
    border-bottom: 1px solid rgba(30, 60, 100, 0.1);
  }
  .cover-proof-item {
    min-width: 0;
  }
  .cover-proof-value,
  .cover-proof-label {
    display: block;
  }
  .cover-proof-value {
    font-size: 16px;
    line-height: 1.15;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--color-ink);
  }
  .cover-proof-label {
    margin-top: 0.35rem;
    font-size: 10px;
    line-height: 1.35;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-3);
  }
  .bio {
    grid-area: bio;
    max-width: 580px;
  }
  .bio p {
    font-size: 15px;
    line-height: 1.75;
    color: var(--color-body);
    margin: 0;
  }
  .bio p + p {
    margin-top: 1rem;
  }
  /* Foto-Brief v6: Karten-Rand (Option B)
     - Hairline 1px in Blau-Grau (#90A6BB) mit 40% Opazitaet -- leicht
       dunkler als der Site-Hellblau, KEIN Weiss
     - Sanfter Box-Shadow aus Option A bleibt fuer zusaetzliche Tiefe
     - Runde Ecken + transparenter BG unveraendert */
  .portrait {
    grid-area: portrait;
    align-self: start;
    width: min(100%, 444px);
    justify-self: start;
    aspect-ratio: 428 / 596; /* natives Verhaeltnis der Bilddatei 856x1192 */
    position: relative;
    background: linear-gradient(
      180deg,
      #a4c0d9 0%,
      #c0d3e4 42%,
      #e2ebf3 78%,
      #f3f7fb 100%
    );
    border: 1px solid rgba(144, 166, 187, 0.32);
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 18px 42px rgba(30, 50, 70, 0.1);
  }
  /* Zwei 18deg-Haarlinien innen (oben rechts), als "Himmel" ueber dem Kopf
     sichtbar -- echoen die Hero-Banner-Linien. */
  .portrait-line-1,
  .portrait-line-2 {
    position: absolute;
    width: 1px;
    transform: rotate(18deg);
    transform-origin: top center;
    pointer-events: none;
  }
  .portrait-line-1 {
    top: -40px;
    right: 64px;
    height: 330px;
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(30, 60, 100, 0.14) 32%,
      rgba(30, 60, 100, 0.04) 75%,
      transparent 100%
    );
  }
  .portrait-line-2 {
    top: 6px;
    right: 122px;
    height: 240px;
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(30, 60, 100, 0.08) 35%,
      rgba(30, 60, 100, 0.02) 75%,
      transparent 100%
    );
  }
  .portrait img {
    position: relative;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center bottom;
  }
  .teaser-area {
    margin-top: 3.5rem;
    padding-bottom: 5.5rem;
  }

  /* --- MOBILE --- Foto ganz oben (ueber der Headline), gestapelt --- */
  @media (max-width: 768px) {
    .hero-inner {
      padding: 2rem 1.5rem 0;
    }
    .hero-grid {
      display: flex;
      flex-direction: column;
      gap: 0;
      margin-bottom: 0;
    }
    .portrait {
      order: 1;
      max-width: 320px;
      width: 100%;
      margin: 0 auto 1.5rem;
      /* Hoehe kommt nur aus aspect-ratio (428/596); Bild fuellt per cover.
         Keine feste height/min-height -> keine Luecke unten. */
    }
    .eyebrow {
      order: 2;
      margin-bottom: 0.75rem;
    }
    .headline {
      order: 3;
      font-size: 32px;
      line-height: 1.06;
      letter-spacing: -0.035em;
      margin-bottom: 1rem;
    }
    .subtitle {
      order: 4;
      margin-bottom: 0;
    }
    .cover-proof {
      order: 5;
      grid-template-columns: 1fr;
      gap: 0.8rem;
      margin: 1.35rem 0 0;
      padding: 1rem 0;
    }
    .ueber-mich-marker {
      order: 6;
      margin-top: 2.5rem;
      padding-top: 2rem;
      margin-bottom: 0;
      border-top: 1px solid var(--color-border);
    }
    .bio {
      order: 7;
      margin-top: 0.75rem;
    }
    .teaser-area {
      margin-top: 2rem;
      padding-bottom: 3rem;
    }
  }
</style>
