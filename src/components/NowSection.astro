---
// Inhalt der Now-Section pflegt Karsten monatlich.
// Marketing-affine Tonalität; keine technischen Detailbegriffe
// (LangGraph, Recall, BOOST, LLM-as-Judge) auf der Hauptseite.
const period = "Mai 2026";
---

<section class="now-section">
  <div class="eyebrow">Was mich gerade beschäftigt ({period})</div>
  <div class="now-grid">
    <div class="now-card">
      <div class="now-card-label">Im Bau</div>
      <p class="now-card-body">AgenticAI Pilot für Digital Marketing</p>
    </div>
  </div>
</section>

<style>
  .now-section {
    position: relative;
    padding-top: 4rem;
    padding-bottom: 5rem;
    border-top: 1px solid var(--color-border);
  }
  .eyebrow {
    font-size: 12px;
    color: var(--color-amber);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    font-weight: 500;
  }
  .now-grid {
    display: block;
    max-width: 520px;
  }
  .now-card {
    background: rgba(255, 255, 255, 0.55);
    border: 1px solid var(--color-border-soft);
    border-radius: 3px;
    padding: 2rem 1.75rem;
  }
  .now-card-label {
    font-size: 11px;
    color: var(--color-ink-3);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 500;
    margin-bottom: 1rem;
  }
  .now-card-body {
    font-size: 15px;
    line-height: 1.75;
    color: var(--color-body);
    margin: 0;
  }
</style>
