---
---

<div class="stats">
  <div>
    <div class="stat-value">25<span class="accent">+</span></div>
    <div class="stat-label">Jahre Digital Commerce</div>
  </div>
  <div>
    <div class="stat-value">€1,6<span class="accent">+</span> Mrd</div>
    <div class="stat-label">Umsatz</div>
  </div>
  <div>
    <div class="stat-value">20<span class="accent">+</span></div>
    <div class="stat-label">EU-Märkte</div>
  </div>
</div>

<style>
  .stats {
    position: relative;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    padding: 2rem 0 3.25rem;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid rgba(30, 60, 100, 0.1);
  }
  .stats > div {
    position: relative;
  }
  .stats > div + div::before {
    content: "";
    position: absolute;
    left: -1rem;
    top: 0.35rem;
    bottom: 0.25rem;
    width: 1px;
    background: rgba(30, 60, 100, 0.1);
  }
  .stat-value {
    font-size: clamp(34px, 3.5vw, 44px);
    font-weight: 500;
    letter-spacing: -0.035em;
    color: var(--color-ink);
    line-height: 1;
  }
  .stat-value .accent {
    color: var(--color-amber);
  }
  .stat-label {
    font-size: 11px;
    color: var(--color-ink-3);
    margin-top: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  @media (max-width: 768px) {
    .stats {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      padding-bottom: 2.5rem;
    }
    .stats > div + div::before {
      display: none;
    }
  }
</style>
