---
import PageHeader from "./PageHeader.astro";

interface Props {
  title: string;
  excerpt?: string;
  date: Date;
  eyebrow: string; // Themen-Label, z.B. "MarTech"
  backHref: string; // z.B. "/martech"
  backLabel: string; // z.B. "MarTech"
}

const { title, excerpt, date, eyebrow, backHref, backLabel } = Astro.props;

const dateFmt = new Intl.DateTimeFormat("de-DE", {
  year: "numeric",
  month: "long",
});
---

<article class="note">
  <a href={backHref} class="note-back">← {backLabel}</a>

  <PageHeader eyebrow={eyebrow} headline={title} intro={excerpt} />

  <div class="note-meta">{dateFmt.format(date)}</div>

  <div class="note-prose">
    <slot />
  </div>
</article>

<style>
  .note {
    max-width: 42rem;
  }
  .note-back {
    display: inline-block;
    font-size: 13px;
    color: var(--color-ink-3);
    text-decoration: none;
    letter-spacing: 0.02em;
    margin-bottom: 2rem;
    transition: color 0.2s ease;
  }
  .note-back:hover {
    color: var(--color-amber);
  }
  .note-meta {
    font-size: 11px;
    color: var(--color-ink-3);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: -2.5rem 0 2.5rem;
  }
  .note-prose {
    padding-top: 3rem;
    border-top: 1px solid var(--color-border);
  }

  /* Markdown-Typografie — bewusst nah an .about-prose (17px, ruhiger Satz) */
  .note-prose :global(p),
  .note-prose :global(ul),
  .note-prose :global(ol) {
    font-size: 17px;
    line-height: 1.75;
    color: var(--color-body);
    margin: 0 0 1.5rem;
  }
  .note-prose :global(ul),
  .note-prose :global(ol) {
    padding-left: 1.4rem;
  }
  .note-prose :global(li) {
    margin-bottom: 0.5rem;
  }
  .note-prose :global(li):last-child {
    margin-bottom: 0;
  }
  .note-prose :global(h2) {
    font-size: 26px;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    line-height: 1.2;
    margin: 3rem 0 1.25rem;
  }
  .note-prose :global(h3) {
    font-size: 20px;
    font-weight: 500;
    letter-spacing: -0.015em;
    color: var(--color-ink);
    line-height: 1.3;
    margin: 2.5rem 0 1rem;
  }
  .note-prose :global(h2:first-child),
  .note-prose :global(h3:first-child) {
    margin-top: 0;
  }
  .note-prose :global(strong) {
    font-weight: 600;
    color: var(--color-ink);
  }
  .note-prose :global(a) {
    color: var(--color-amber);
    text-decoration: none;
    border-bottom: 1px solid rgba(180, 83, 9, 0.3);
    transition: border-color 0.2s ease;
  }
  .note-prose :global(a:hover) {
    border-bottom-color: rgba(180, 83, 9, 0.7);
  }
  .note-prose :global(blockquote) {
    margin: 0 0 1.5rem;
    padding: 0.25rem 0 0.25rem 1.5rem;
    border-left: 3px solid var(--color-amber);
    color: var(--color-ink-2);
    font-style: italic;
  }
  .note-prose :global(blockquote p) {
    margin-bottom: 0.75rem;
  }
  .note-prose :global(blockquote p:last-child) {
    margin-bottom: 0;
  }
  .note-prose :global(code) {
    font-family: "SF Mono", Consolas, Monaco, monospace;
    font-size: 14px;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid var(--color-border-soft);
    padding: 0.1rem 0.35rem;
    border-radius: 3px;
  }
  .note-prose :global(pre) {
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid var(--color-border-soft);
    border-radius: 6px;
    padding: 1rem 1.25rem;
    overflow-x: auto;
    margin: 0 0 1.5rem;
  }
  .note-prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: 13.5px;
    line-height: 1.6;
  }
  .note-prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2.5rem 0;
  }
  .note-prose :global(:last-child) {
    margin-bottom: 0;
  }
</style>
