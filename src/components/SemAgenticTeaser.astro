<style>
  .sa-wrap {
    max-width: 900px;
    width: 100%;
    margin: 0 auto;
  }
  .sa-eyebrow {
    font-size: 12px;
    color: #b45309;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 0.6rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .sa-pulse-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #b45309;
  }
  .sa-sub {
    font-size: 15px;
    line-height: 1.5;
    color: #3a4f6c;
    margin: 0 0 1.5rem;
    max-width: 62ch;
  }

  /* Zwei gleich große Karten (Site-Card-Pattern) */
  .sa-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .sa-card {
    display: flex;
    flex-direction: column;
    /* opaker + Schatten: der Body-Gradient ist fixed, sonst verschwinden die
       Karten im weissen Viewport-Bereich */
    background: rgba(255, 255, 255, 0.82);
    border: 1px solid rgba(30, 60, 100, 0.16);
    border-radius: 3px;
    box-shadow: 0 2px 14px rgba(30, 60, 100, 0.07);
    padding: 1.5rem 1.5rem;
    text-decoration: none;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease,
      transform 0.2s ease;
  }
  .sa-card:hover {
    border-color: rgba(180, 83, 9, 0.45);
    box-shadow: 0 6px 22px rgba(30, 60, 100, 0.12);
    transform: translateY(-2px);
  }
  .sa-card-label {
    font-size: 11px;
    color: #5b6b82;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 0.6rem;
  }
  .sa-card-name {
    font-size: 22px;
    font-weight: 600;
    color: #0f1729;
    letter-spacing: -0.02em;
    line-height: 1.15;
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 0.55rem;
  }
  .sa-card-arrow {
    color: #b45309;
    font-size: 18px;
    transition: transform 0.2s ease;
    display: inline-block;
  }
  .sa-card:hover .sa-card-arrow {
    transform: translateX(4px);
  }
  .sa-card-line {
    font-size: 14px;
    line-height: 1.55;
    color: #2a3d55;
    margin: 0 0 1.1rem;
    flex: 1 1 auto;
  }
  .sa-card-tag {
    font-size: 11px;
    color: #5b6b82;
    letter-spacing: 0.04em;
    margin-top: auto;
    padding-top: 0.7rem;
    border-top: 1px solid rgba(30, 60, 100, 0.1);
  }

  @media (max-width: 640px) {
    .sa-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
