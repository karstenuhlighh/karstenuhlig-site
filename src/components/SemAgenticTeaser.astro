---
---

<div class="sa-wrap">
  <div class="sa-eyebrow">
    <span class="sa-pulse-dot"></span> Feasibility Study
  </div>
  <h2 class="sa-hook-title">sem-agentic — Agentic AI im Google SEM</h2>

  <div class="sa-schaubild">
    <div class="sa-flow-label">
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="#5B6B82"
        stroke-width="2"
        stroke-linecap="round"
      >
        <circle cx="11" cy="11" r="7"></circle>
        <line x1="16" y1="16" x2="21" y2="21"></line>
      </svg>
      Google SEM — Workflow in 5 Schritten
    </div>

    <div class="sa-steps">
      <div class="sa-flow-track">
        <div class="sa-flow-particle"></div>
        <div class="sa-flow-particle"></div>
        <div class="sa-flow-particle"></div>
      </div>
      <div class="sa-step">
        <div class="sa-step-bubble">1</div>
        <div class="sa-step-label">Keyword-<br />Recherche</div>
      </div>
      <div class="sa-step">
        <div class="sa-step-bubble">2</div>
        <div class="sa-step-label">Kampagnen-<br />struktur</div>
      </div>
      <div class="sa-step">
        <div class="sa-step-bubble">3</div>
        <div class="sa-step-label">Anzeigen-<br />texte</div>
      </div>
      <div class="sa-step">
        <div class="sa-step-bubble">4</div>
        <div class="sa-step-label">Gebots-<br />strategie</div>
      </div>
      <div class="sa-step">
        <div class="sa-step-bubble">5</div>
        <div class="sa-step-label">Optimierung<br />&amp; Analyse</div>
      </div>
    </div>

    <div class="sa-connectors">
      <div class="sa-connector"></div>
      <div class="sa-connector"></div>
      <div class="sa-connector"></div>
      <div class="sa-connector"></div>
      <div class="sa-connector"></div>
    </div>

    <div class="sa-ai-layer">
      <div class="sa-ai-icon">
        <svg
          viewBox="0 0 32 32"
          fill="none"
          stroke="#B45309"
          stroke-width="1.7"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="16" y1="3.5" x2="16" y2="8"></line>
          <circle cx="16" cy="2.6" r="1.5" fill="#B45309" stroke="none"
          ></circle>
          <rect x="6" y="8" width="20" height="16" rx="4"></rect>
          <circle cx="12" cy="15" r="2" fill="#B45309" stroke="none"></circle>
          <circle cx="20" cy="15" r="2" fill="#B45309" stroke="none"></circle>
          <line x1="12.5" y1="19.5" x2="19.5" y2="19.5"></line>
          <line x1="3" y1="13.5" x2="3" y2="18.5"></line>
          <line x1="29" y1="13.5" x2="29" y2="18.5"></line>
        </svg>
      </div>
      <div>
        <div class="sa-ai-text-title">sem-agentic — Agentic AI System</div>
        <div class="sa-ai-text-sub">
          Ein agentisches System, das in diesem Workflow analysiert und
          Optimierungen vorschlägt. Hands-on gebaut.
        </div>
        <div class="sa-ai-badges">
          <span class="sa-badge">Scale</span>
          <span class="sa-badge">Maintain</span>
          <span class="sa-badge">Investigate</span>
          <span class="sa-badge">Pause</span>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .sa-wrap {
    max-width: 900px;
    width: 100%;
    margin: 0 auto;
  }
  .sa-eyebrow {
    font-size: 12px;
    color: #b45309;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .sa-pulse-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #b45309;
    animation: sa-livepulse 1.8s ease-in-out infinite;
  }
  @keyframes sa-livepulse {
    0%,
    100% {
      opacity: 1;
      box-shadow: 0 0 0 0 rgba(180, 83, 9, 0.5);
    }
    50% {
      opacity: 0.6;
      box-shadow: 0 0 0 6px rgba(180, 83, 9, 0);
    }
  }
  .sa-hook-title {
    font-size: 30px;
    font-weight: 600;
    color: #0f1729;
    letter-spacing: -0.025em;
    margin-bottom: 2.25rem;
    line-height: 1.12;
  }
  .sa-schaubild {
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.6),
      rgba(255, 255, 255, 0.35)
    );
    border: 1px solid rgba(30, 60, 100, 0.14);
    border-radius: 14px;
    padding: 2.5rem 2rem 2rem;
    position: relative;
    overflow: hidden;
  }
  .sa-schaubild::before {
    content: "";
    position: absolute;
    top: -40%;
    right: -10%;
    width: 320px;
    height: 320px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(180, 83, 9, 0.07),
      transparent 70%
    );
    pointer-events: none;
  }
  .sa-flow-label {
    font-size: 11px;
    color: #5b6b82;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 1.75rem;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }
  .sa-flow-label svg {
    width: 14px;
    height: 14px;
  }
  .sa-step-bubble {
    width: 56px;
    height: 56px;
    border-radius: 16px;
    flex-shrink: 0;
    background: linear-gradient(145deg, #ffffff, #eaf0f6);
    border: 1.5px solid rgba(30, 60, 100, 0.18);
    box-shadow: 0 4px 14px rgba(30, 60, 100, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 19px;
    font-weight: 700;
    color: #1e3a5f;
    position: relative;
    z-index: 2;
    animation: sa-float 3s ease-in-out infinite;
  }
  @keyframes sa-float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-6px);
    }
  }
  .sa-step-label {
    font-size: 12.5px;
    color: #2a3d55;
    line-height: 1.35;
    font-weight: 500;
  }

  /* ---------- DESKTOP (horizontal) ---------- */
  .sa-steps {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.4rem;
    margin-bottom: 1rem;
    position: relative;
  }
  .sa-step {
    flex: 1;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .sa-step .sa-step-bubble {
    margin-bottom: 0.85rem;
  }
  .sa-step:nth-child(2) .sa-step-bubble {
    animation-delay: 0s;
  }
  .sa-step:nth-child(3) .sa-step-bubble {
    animation-delay: 0.3s;
  }
  .sa-step:nth-child(4) .sa-step-bubble {
    animation-delay: 0.6s;
  }
  .sa-step:nth-child(5) .sa-step-bubble {
    animation-delay: 0.9s;
  }
  .sa-step:nth-child(6) .sa-step-bubble {
    animation-delay: 1.2s;
  }
  .sa-flow-track {
    position: absolute;
    top: 28px;
    left: 8%;
    right: 8%;
    height: 2px;
    background: rgba(30, 60, 100, 0.12);
    z-index: 1;
  }
  .sa-flow-particle {
    position: absolute;
    top: -2px;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #b45309;
    box-shadow: 0 0 8px rgba(180, 83, 9, 0.7);
    animation: sa-travelX 3.5s linear infinite;
  }
  .sa-flow-particle:nth-child(2) {
    animation-delay: 1.2s;
  }
  .sa-flow-particle:nth-child(3) {
    animation-delay: 2.4s;
  }
  @keyframes sa-travelX {
    0% {
      left: 0%;
      opacity: 0;
    }
    10% {
      opacity: 1;
    }
    90% {
      opacity: 1;
    }
    100% {
      left: 100%;
      opacity: 0;
    }
  }
  .sa-connectors {
    display: flex;
    justify-content: space-around;
    margin: 1.25rem 0 0.75rem;
  }
  .sa-connector {
    width: 2px;
    height: 32px;
    background: linear-gradient(
      180deg,
      rgba(180, 83, 9, 0.5),
      rgba(180, 83, 9, 0.15)
    );
    border-radius: 2px;
    position: relative;
  }
  /* 5. Connector als Pfeil nach oben zu "Optimierung & Analyse" --
     signalisiert, dass das Agentic-AI-System hier eingreift. */
  .sa-connector:nth-child(5) {
    background: linear-gradient(
      180deg,
      rgba(180, 83, 9, 0.85),
      rgba(180, 83, 9, 0.3)
    );
  }
  .sa-connector:nth-child(5)::before {
    content: "";
    position: absolute;
    top: -7px;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 0;
    border-left: 7px solid transparent;
    border-right: 7px solid transparent;
    border-bottom: 9px solid rgba(180, 83, 9, 0.9);
  }

  .sa-ai-layer {
    background: linear-gradient(
      135deg,
      rgba(180, 83, 9, 0.1),
      rgba(180, 83, 9, 0.04)
    );
    border: 1.5px solid rgba(180, 83, 9, 0.35);
    border-radius: 12px;
    padding: 1.6rem 1.9rem;
    display: flex;
    align-items: center;
    gap: 1.4rem;
    position: relative;
    overflow: hidden;
  }
  .sa-ai-icon {
    width: 54px;
    height: 54px;
    border-radius: 13px;
    flex-shrink: 0;
    background: linear-gradient(
      145deg,
      rgba(180, 83, 9, 0.18),
      rgba(180, 83, 9, 0.08)
    );
    border: 1.5px solid rgba(180, 83, 9, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    animation: sa-float 3.4s ease-in-out infinite;
  }
  .sa-ai-icon svg {
    width: 32px;
    height: 32px;
  }
  .sa-ai-text-title {
    font-size: 16px;
    font-weight: 600;
    color: #0f1729;
    margin-bottom: 0.25rem;
  }
  .sa-ai-text-sub {
    font-size: 13px;
    color: #3a4f6c;
    line-height: 1.45;
  }
  .sa-ai-badges {
    display: flex;
    gap: 0.4rem;
    margin-top: 0.7rem;
    flex-wrap: wrap;
  }
  .sa-badge {
    font-size: 10.5px;
    font-weight: 600;
    padding: 3px 9px;
    border-radius: 20px;
    background: rgba(180, 83, 9, 0.1);
    color: #b45309;
    border: 1px solid rgba(180, 83, 9, 0.25);
  }

  /* ---------- MOBILE (vertikal gestapelt) ---------- */
  @media (max-width: 640px) {
    .sa-hook-title {
      font-size: 24px;
    }
    .sa-schaubild {
      padding: 1.75rem 1.25rem 1.5rem;
      border-radius: 12px;
    }
    .sa-steps {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      margin-bottom: 0.5rem;
      position: relative;
    }
    .sa-step {
      flex-direction: row;
      align-items: center;
      text-align: left;
      gap: 1rem;
      padding: 0.55rem 0;
      position: relative;
      z-index: 2;
    }
    .sa-step .sa-step-bubble {
      margin-bottom: 0;
      width: 46px;
      height: 46px;
      font-size: 16px;
      animation: sa-floatY 3s ease-in-out infinite;
    }
    @keyframes sa-floatY {
      0%,
      100% {
        transform: translateX(0);
      }
      50% {
        transform: translateX(4px);
      }
    }
    .sa-step-label {
      font-size: 14px;
    }
    .sa-step-label br {
      display: none;
    }

    .sa-flow-track {
      display: block;
      top: 30px;
      bottom: 30px;
      left: 22px;
      width: 2px;
      height: auto;
      right: auto;
      background: linear-gradient(
        180deg,
        rgba(180, 83, 9, 0.45),
        rgba(180, 83, 9, 0.15)
      );
      z-index: 0;
    }
    .sa-flow-particle {
      top: 0;
      left: -2.5px;
      right: auto;
      animation: sa-travelY 3.5s linear infinite;
    }
    .sa-flow-particle:nth-child(2) {
      animation-delay: 1.2s;
    }
    .sa-flow-particle:nth-child(3) {
      animation-delay: 2.4s;
    }
    @keyframes sa-travelY {
      0% {
        top: 0%;
        opacity: 0;
      }
      10% {
        opacity: 1;
      }
      90% {
        opacity: 1;
      }
      100% {
        top: 100%;
        opacity: 0;
      }
    }

    .sa-connectors {
      display: none;
    }
    .sa-ai-layer {
      flex-direction: column;
      text-align: center;
      gap: 1rem;
      margin-top: 1.25rem;
      padding: 1.5rem 1.25rem;
    }
    .sa-ai-badges {
      justify-content: center;
    }
  }
</style>
