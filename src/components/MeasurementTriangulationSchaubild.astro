    margin-bottom: 0.7rem;
  }
  .mts-lenses {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.6rem;
    margin-bottom: 0.7rem;
  }
  .mts-lens {
    border-radius: 8px;
    padding: 0.6rem 0.7rem;
    text-align: center;
  }
  .ml-t {
    font-size: 12.5px;
    font-weight: 600;
  }
  .ml-s {
    font-size: 11px;
    margin-top: 2px;
    color: var(--color-ink-3);
  }
  /* ---- Ergebnis (kein gebautes Element: eigener Stil) ---- */
  .mts-down {
    text-align: center;
    color: var(--color-ink-3);
    font-size: 16px;
