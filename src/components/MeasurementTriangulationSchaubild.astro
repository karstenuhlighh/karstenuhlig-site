  }

  @media (max-width: 560px) {
    .mts-top {
      flex-direction: column;
    }
    .mts-conn {
      transform: rotate(90deg);
    }
    .mts-lenses,
    .mts-market-grid {
      grid-template-columns: 1fr;
    }
    .mts-loop {
      right: 8px;
    }
  }
</style>
