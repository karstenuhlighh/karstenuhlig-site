    font-size: 14px;
    font-weight: 600;
  }
  .mts-box-s {
    font-size: 11.5px;
    color: var(--color-ink-3);
    margin-top: 2px;
  }
  .mts-conn {
    align-self: center;
    color: var(--color-ink-3);
    font-size: 18px;
    flex: 0 0 auto;
  }
  /* ---- Triangulation panel ---- */
  .mts-panel {
    border: 1px dashed var(--color-border);
    border-radius: 11px;
    padding: 0.85rem 0.95rem 1rem;
    margin-bottom: 1.1rem;
  }
