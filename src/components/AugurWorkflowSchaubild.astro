---
// Augur-Schaubild: Google SEM Workflow in 5 Schritten + AI-Layer.
// Übernommen 1:1 aus dem ursprünglichen SemAgenticTeaser-Schaubild,
// jetzt eigenständig nutzbar auf der sem-agentic-Detailseite.
---

<div class="awf-wrap">
  <div class="awf-schaubild">
    <div class="awf-flow-label">
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="#5B6B82"
        stroke-width="2"
        stroke-linecap="round"
      >
        <circle cx="11" cy="11" r="7"></circle>
        <line x1="16" y1="16" x2="21" y2="21"></line>
      </svg>
      Google SEM · Workflow in 5 Schritten
    </div>

    <div class="awf-steps">
      <div class="awf-step">
        <div class="awf-step-label">1. Keyword-<br />Recherche</div>
      </div>
      <div class="awf-step">
        <div class="awf-step-label">2. Kampagnen-<br />struktur</div>
      </div>
      <div class="awf-step">
        <div class="awf-step-label">3. Anzeigen-<br />texte</div>
      </div>
      <div class="awf-step">
        <div class="awf-step-label">4.<br />Gebots-<br />strategie</div>
      </div>
      <div class="awf-step">
        <div class="awf-step-label">5. Optimierung<br />&amp; Analyse</div>
      </div>
    </div>

    <div class="awf-connectors">
      <div class="awf-connector"></div>
      <div class="awf-connector"></div>
      <div class="awf-connector"></div>
      <div class="awf-connector"></div>
      <div class="awf-connector"></div>
    </div>

    <div class="awf-ai-layer">
      <div class="awf-ai-icon">
        <svg
          viewBox="0 0 32 32"
          fill="none"
          stroke="#B45309"
          stroke-width="1.7"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="16" y1="3.5" x2="16" y2="8"></line>
          <circle cx="16" cy="2.6" r="1.5" fill="#B45309" stroke="none"
          ></circle>
          <rect x="6" y="8" width="20" height="16" rx="4"></rect>
          <circle cx="12" cy="15" r="2" fill="#B45309" stroke="none"></circle>
          <circle cx="20" cy="15" r="2" fill="#B45309" stroke="none"></circle>
          <line x1="12.5" y1="19.5" x2="19.5" y2="19.5"></line>
          <line x1="3" y1="13.5" x2="3" y2="18.5"></line>
          <line x1="29" y1="13.5" x2="29" y2="18.5"></line>
        </svg>
      </div>
      <div class="awf-ai-body">
        <div class="awf-ai-text-title">sem-agentic · Agentic AI System</div>
        <div class="awf-ai-text-sub">
          Ein agentisches System, das in diesem Workflow analysiert und
          Optimierungen vorschlägt. Hands-on entwickelt.
        </div>
        <div class="awf-ai-badges">
          <span class="awf-badge">Scale</span>
          <span class="awf-badge">Maintain</span>
          <span class="awf-badge">Investigate</span>
          <span class="awf-badge">Pause</span>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .awf-wrap {
    max-width: 900px;
    width: 100%;
    margin: 0 auto;
  }
  .awf-schaubild {
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.6),
      rgba(255, 255, 255, 0.35)
    );
    border: 1px solid rgba(30, 60, 100, 0.14);
    border-radius: 14px;
    padding: 1.1rem 1.4rem;
    position: relative;
    overflow: hidden;
  }
  .awf-schaubild::before {
    content: "";
    position: absolute;
    top: -40%;
    right: -10%;
    width: 320px;
    height: 320px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(180, 83, 9, 0.07),
      transparent 70%
    );
    pointer-events: none;
  }
  .awf-flow-label {
    font-size: 11px;
    color: #5b6b82;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 0.7rem;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }
  .awf-flow-label svg {
    width: 14px;
    height: 14px;
  }
  .awf-step-bubble {
    width: 56px;
    height: 56px;
    border-radius: 16px;
    flex-shrink: 0;
    background: linear-gradient(145deg, #ffffff, #eaf0f6);
    border: 1.5px solid rgba(30, 60, 100, 0.18);
    box-shadow: 0 4px 14px rgba(30, 60, 100, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 19px;
    font-weight: 700;
    color: #1e3a5f;
    position: relative;
    z-index: 2;
  }
  .awf-step-label {
    font-size: 12.5px;
    color: #2a3d55;
    line-height: 1.35;
    font-weight: 500;
  }

  /* ---------- DESKTOP (horizontal) ---------- */
  .awf-steps {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.4rem;
    margin-bottom: 0.3rem;
    position: relative;
  }
  .awf-step {
    flex: 1;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .awf-step .awf-step-bubble {
    margin-bottom: 0.4rem;
  }
  .awf-flow-track {
    position: absolute;
    top: 28px;
    left: 8%;
    right: 8%;
    height: 2px;
    background: rgba(30, 60, 100, 0.12);
    z-index: 1;
  }
  .awf-connectors {
    display: flex;
    justify-content: space-around;
    margin: 0.4rem 0 0.4rem;
  }
  .awf-connector {
    width: 2px;
    height: 14px;
    background: linear-gradient(
      180deg,
      rgba(180, 83, 9, 0.5),
      rgba(180, 83, 9, 0.15)
    );
    border-radius: 2px;
  }
  .awf-ai-layer {
    background: linear-gradient(
      135deg,
      rgba(180, 83, 9, 0.1),
      rgba(180, 83, 9, 0.04)
    );
    border: 1.5px solid rgba(180, 83, 9, 0.35);
    border-radius: 12px;
    padding: 0.85rem 1.15rem;
    display: flex;
    align-items: center;
    gap: 1.4rem;
    position: relative;
    overflow: hidden;
  }
  .awf-ai-body {
    flex: 1;
  }
  .awf-ai-icon {
    width: 54px;
    height: 54px;
    border-radius: 13px;
    flex-shrink: 0;
    background: linear-gradient(
      145deg,
      rgba(180, 83, 9, 0.18),
      rgba(180, 83, 9, 0.08)
    );
    border: 1.5px solid rgba(180, 83, 9, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .awf-ai-icon svg {
    width: 32px;
    height: 32px;
  }
  .awf-ai-text-title {
    font-size: 16px;
    font-weight: 600;
    color: #0f1729;
    margin-bottom: 0.25rem;
  }
  .awf-ai-text-sub {
    font-size: 13px;
    color: #3a4f6c;
    line-height: 1.45;
  }
  .awf-ai-badges {
    display: flex;
    gap: 0.4rem;
    margin-top: 0.7rem;
    flex-wrap: wrap;
  }
  .awf-badge {
    font-size: 10.5px;
    font-weight: 600;
    padding: 3px 9px;
    border-radius: 20px;
    background: rgba(180, 83, 9, 0.1);
    color: #b45309;
    border: 1px solid rgba(180, 83, 9, 0.25);
  }

  /* ---------- MOBILE (vertikal gestapelt) ---------- */
  @media (max-width: 640px) {
    .awf-schaubild {
      padding: 1.75rem 1.25rem 1.5rem;
      border-radius: 12px;
    }
    .awf-steps {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      margin-bottom: 0.5rem;
      position: relative;
    }
    .awf-step {
      flex-direction: row;
      align-items: center;
      text-align: left;
      gap: 1rem;
      padding: 0.55rem 0;
      position: relative;
      z-index: 2;
    }
    .awf-step .awf-step-bubble {
      margin-bottom: 0;
      width: 46px;
      height: 46px;
      font-size: 16px;
    }
    .awf-step-label {
      font-size: 14px;
    }
    .awf-step-label br {
      display: none;
    }
    .awf-flow-track {
      display: block;
      top: 30px;
      bottom: 30px;
      left: 22px;
      width: 2px;
      height: auto;
      right: auto;
      background: linear-gradient(
        180deg,
        rgba(180, 83, 9, 0.45),
        rgba(180, 83, 9, 0.15)
      );
      z-index: 0;
    }
    .awf-connectors {
      display: none;
    }
    .awf-ai-layer {
      flex-direction: column;
      text-align: center;
      gap: 1rem;
      margin-top: 1.25rem;
      padding: 1.5rem 1.25rem;
    }
    .awf-ai-badges {
      justify-content: center;
    }
  }
</style>
