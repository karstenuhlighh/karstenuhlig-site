---
const bullets = [
  "€1,6 Mrd. E-Commerce über 20+ EU-Märkte verantwortet",
  "Internationale Digital-Marketing-Operation von 0 auf 50% Traffic-Anteil aufgebaut",
  "120 Mitarbeitende in 25 Teams geführt, €30 Mio. Budget verantwortet",
  "KI/ML-Organisation aufgebaut, mehrere Use Cases produktiv im Einsatz",
  "Speaker bei eTail Germany",
];
---

<section class="track-record">
  <div class="eyebrow">Track Record</div>
  <h2 class="track-headline">bonprix (Otto Group), 2000–Juni 2025</h2>
  <p class="track-intro">
    Eingestiegen 2000 als Projektmanager E-Commerce, zuletzt VP Product &amp;
    Technology. Dazwischen Stationen in Digital Marketing, Sales und
    Tech-Leadership. Werkstudent bei bonprix bereits 1997–1999.
  </p>
  <ul class="track-bullets">
    {bullets.map((b) => <li>{b}</li>)}
  </ul>
</section>

<style>
  .track-record {
    position: relative;
    padding-top: 4rem;
    padding-bottom: 4rem;
    border-top: 1px solid var(--color-border);
  }
  .eyebrow {
    font-size: 12px;
    color: var(--color-amber);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    font-weight: 500;
  }
  .track-headline {
    font-size: 28px;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    line-height: 1.2;
    margin: 0 0 1rem;
  }
  .track-intro {
    font-size: 15px;
    line-height: 1.75;
    color: var(--color-body);
    max-width: 680px;
    margin: 0 0 2rem;
  }
  .track-bullets {
    list-style: none;
    padding: 0;
    margin: 0;
    max-width: 720px;
  }
  .track-bullets li {
    font-size: 15px;
    line-height: 1.75;
    color: var(--color-body);
    padding-left: 1.5rem;
    position: relative;
  }
  .track-bullets li + li {
    margin-top: 0.5rem;
  }
  .track-bullets li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.85em;
    width: 10px;
    height: 1px;
    background: var(--color-amber);
  }
</style>
