---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Impressum — Karsten Uhlig">
  <div class="max-w-[720px] mx-auto px-8 py-24">
    <h1 class="text-4xl font-medium tracking-tight text-[#0F1729] mb-12">Impressum</h1>

    <div class="space-y-8 text-[15px] leading-relaxed text-[#2A3D55]">
      <div>
        <p>Karsten Uhlig</p>
        <p>Friedensallee 29</p>
        <p>22765 Hamburg</p>
      </div>

      <div>
        <p class="text-[11px] tracking-widest uppercase text-[#5B6B82] mb-2">Kontakt</p>
        <p>
          E-Mail:
          <a href="mailto:mail@karstenuhlig.de" class="text-[#B45309] hover:underline">
            mail@karstenuhlig.de
          </a>
        </p>
      </div>
    </div>

    <div class="mt-16">
      <a href="/" class="text-[13px] text-[#3A4F6C] hover:text-[#0F1729]">← Zurück</a>
    </div>
  </div>
</Layout>
