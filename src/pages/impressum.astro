---
import SubPageLayout from "../layouts/SubPageLayout.astro";
import PageHeader from "../components/PageHeader.astro";
---

<SubPageLayout
  title="Impressum — Karsten Uhlig"
  description="Impressum nach § 5 TMG."
>
  <PageHeader eyebrow="Rechtliches" headline="Impressum" />

  <section class="legal-content">
    <div class="address">
      <p>Karsten Uhlig</p>
      <p>Friedensallee 29</p>
      <p>22765 Hamburg</p>
    </div>

    <div class="contact">
      <p class="label">Kontakt</p>
      <p>
        E-Mail: <a href="mailto:mail@karstenuhlig.de"
          >mail@karstenuhlig.de</a
        >
      </p>
    </div>
  </section>
</SubPageLayout>

<style>
  .legal-content {
    max-width: 720px;
    padding-top: 3rem;
    border-top: 1px solid var(--color-border);
    color: var(--color-body);
    font-size: 15px;
    line-height: 1.75;
  }
  .legal-content p {
    margin: 0;
  }
  .legal-content a {
    color: var(--color-amber);
    text-decoration: none;
  }
  .legal-content a:hover {
    text-decoration: underline;
  }
  .address {
    margin-bottom: 2.5rem;
  }
  .contact .label {
    font-size: 11px;
    color: var(--color-ink-3);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
    font-weight: 500;
  }
</style>
