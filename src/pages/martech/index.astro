---
import { getCollection } from "astro:content";
import SubPageLayout from "../../layouts/SubPageLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import NotesList from "../../components/NotesList.astro";

const notes = await getCollection("martech", ({ data }) => !data.draft);
notes.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<SubPageLayout
  title="MarTech — Karsten Uhlig"
  description="Wie ein MarTech-Stack tatsächlich Commerce-Outcomes erzeugt — Operating Model, Datenarchitektur, Anwendungen."
>
  <PageHeader
    eyebrow="Bereich"
    headline="MarTech"
    intro="Wie ein Stack tatsächlich Commerce-Outcomes erzeugt. Operating Model, Datenarchitektur, Anwendungen, die produktiv laufen."
  />
  <NotesList notes={notes} basePath="/martech" />
</SubPageLayout>
