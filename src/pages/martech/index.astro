---
import { getCollection } from "astro:content";
import SubPageLayout from "../../layouts/SubPageLayout.astro";
import PageHeader from "../../components/PageHeader.astro";
import NotesList from "../../components/NotesList.astro";

const notes = await getCollection("martech", ({ data }) => !data.draft);
notes.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<SubPageLayout
  title="MarTech | Karsten Uhlig"
  description="Die Schicht unter dem Geschäftsergebnis. Datenarchitektur, Operating Model und Anwendungen, die produktiv laufen."
>
  <PageHeader
    eyebrow="Bereich"
    headline="MarTech"
    intro="Die Schicht unter dem Geschäftsergebnis, die es trägt. Datenarchitektur, Operating Model und Anwendungen, die produktiv laufen."
  />
  <NotesList notes={notes} basePath="/martech" />
</SubPageLayout>
