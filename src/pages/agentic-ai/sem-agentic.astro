    color: var(--color-ink-3);
  }
  .duo-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
    margin-bottom: 0.7rem;
  }
  .duo {
    border-radius: 6px;
    padding: 0.55rem;
  }
  .duo-title {
    font-size: 10.5px;
    font-weight: 500;
    margin-bottom: 0.35rem;
    text-align: center;
  }
  .duo-title-lg {
    font-size: 13px;
    font-weight: 500;
    margin-bottom: 0.15rem;
    text-align: center;
  }
  .duo-sub {
