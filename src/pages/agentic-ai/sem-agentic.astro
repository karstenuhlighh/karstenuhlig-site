---
import SubPageLayout from "../../layouts/SubPageLayout.astro";
import AugurWorkflowSchaubild from "../../components/AugurWorkflowSchaubild.astro";
import ScopeSteckbrief from "../../components/ScopeSteckbrief.astro";

// ============================================================
// SCOPE-STECKBRIEF — Inhalte (nur hier, Komponente bleibt generisch)
// ============================================================
const scopeFelder = [
  {
    label: "Zielsetzung",
    essence:
      `Architektur statt reiner Prompt-Logik. Und den Abstand zwischen Demo und Betrieb von innen verstehen.`,
    detail:
      "Ich wollte prüfen, wie weit sich ein agentisches System für Google SEM mit sauberer Architektur, Validierung und Rollout-Logik bringen lässt. Ein produktionsreifes System war nicht das Ziel.",
  },
  {
    label: "Vorgehen",
    essence:
      "Fünf validierte Agenten, ein Coordinator mit Selbstprüfung, gestufter Rollout.",
    detail:
      "Jeder Agent erzeugt begründete Vorschläge und wird passend zu seinem Ergebnis geprüft: Shadow-Log und Human Review, LLM-as-a-Judge oder Hypothesentests. Ein Strategy-Coordinator verdichtet die Ergebnisse zu einer nachvollziehbaren Empfehlung. Deterministische Logik, wo die Regeln klar sind; ein LLM nur dort, wo es Mehrwert bringt. Die Ausführung läuft stufenweise: Shadow → Sandbox → Limited Live → Autonomous.",
  },
  {
    label: "Rolle der agentischen KI",
    essence:
      "Der Engpass liegt nicht im Prompting, sondern in der Architektur darum herum.",
    detail:
      "Beobachtung aus diesem Fall: Validierung je Ergebnisart, Koordination mehrerer Agenten, gestufter Rollout und nachvollziehbare Evaluation. Erst diese Disziplin trennt eine Demo von etwas Betreibbarem. Welche Vorschläge übernommen werden und ab welcher Rollout-Stufe ein Agent autonom handeln darf, bleibt eine bewusst gesetzte, menschliche Entscheidung.",
  },
];
const scopeGeltung = {
  belegt: [
    "Agentisches SEM-System als laufender Pilot",
    "Validierung je Agent und koordinierte Verdichtung",
    "Dokumentierte Evaluation (ADRs, Eval-Framework, Audit)",
  ],
  nichtBelegt: [
    "Autonomer Live-Betrieb",
    "Wirkung im Maßstab",
    "Performance-Grundlage teils synthetisch",
    "Ausführung in frühen Rollout-Stufen, unter menschlicher Kontrolle",
  ],
};

// ============================================================
// TAB 1 — WORKING & PRODUCT MAP DATA
// ============================================================
const claudeChatItems = [
  "Strategy & Sparring",
  "VP-Story Material",
  "Reflection & Memory",
  "Documents & Visuals",
];
const claudeCodeItems = [
  "Code-Stand prüfen",
  "Architektur-Skizze",
  "Services entwickeln",
  "ADRs & Tests",
];

const maturityLegend = [
  { lvl: "0", text: "not present", bg: "#D3D1C7", fg: "#2C2C2A" },
  { lvl: "1", text: "aware", bg: "#F5C4B3", fg: "#4A1B0C" },
  { lvl: "2", text: "repeatable", bg: "#FAC775", fg: "#412402" },
  { lvl: "3", text: "defined", bg: "#C0DD97", fg: "#173404" },
  { lvl: "4", text: "managed", bg: "#97C459", fg: "#173404" },
  { lvl: "5", text: "optim.", bg: "#639922", fg: "#FFFFFF" },
];

type Pillar = {
  letter: string;
  title: string;
  score: string;
  accent: string;
  items: { name: string; level: 0 | 1 | 2 | 3 | 4 | 5 }[];
};

const pillars: Pillar[] = [
  {
    letter: "A",
    title: "engineering discipline",
    score: "15/20",
    accent: "#534AB7",
    items: [
      { name: "stage-1/2 build", level: 3 },
      { name: "pre-flight audit", level: 4 },
      { name: "discrepancy-driven", level: 4 },
      { name: "hard-fail senior", level: 4 },
    ],
  },
  {
    letter: "B",
    title: "knowledge & workspace",
    score: "16/30",
    accent: "#378ADD",
    items: [
      { name: "cross-chat memory", level: 2 },
      { name: "conversation recall", level: 2 },
      { name: "audit + re-audit", level: 3 },
      { name: "reusable prompts", level: 3 },
      { name: "shared workspace", level: 4 },
      { name: "tiered knowledge", level: 3 },
    ],
  },
  {
    letter: "C",
    title: "agentic system architecture",
    score: "2/20",
    accent: "#BA7517",
    items: [
      { name: "skills-system", level: 1 },
      { name: "goal-setter", level: 1 },
      { name: "background-routines", level: 0 },
      { name: "mcp-integration", level: 0 },
    ],
  },
  {
    letter: "D",
    title: "quality & observability",
    score: "5/20",
    accent: "#1D9E75",
    items: [
      { name: "eval-driven ci", level: 2 },
      { name: "observability+cost", level: 2 },
      { name: "a/b prompt-testing", level: 0 },
      { name: "self-maintenance", level: 1 },
    ],
  },
];

const adrTags = [
  "project.md",
  "status.md",
  "adrs/ ·15",
  "reflections/",
  "audit.md",
  "backlog.md",
];

const features = [
  {
    title: "Zwei-Schichten-Architektur (ADR-015)",
    body: "Deterministische Action-Schicht (Pre-flight Rules) + optionale LLM-Analyst-Schicht. Schicht 2 unter Beweisvorbehalt, nicht umgesetzt bis Mehrwert belegt.",
  },
  {
    title: "Two-Track Eval (ADR-013)",
    body: "F1 vs Domain-Ground-Truth + Rule-Compliance orthogonal. Belegt: LLM hält 6% der Constraints von selbst, Deterministik rettet 94%.",
  },
  {
    title: "Cluster-Aggregation gegen Prompt-Kollaps (ADR-014)",
    body: "626 Keyword-Forced-Recs → 17 Cluster-Forderungen, Prompt 33k→3-4k Tokens. 0 Determinismus-Violations über N Läufe.",
  },
  {
    title: "LLM-Backend pro Step wählbar",
    body: "Sonnet für Reasoning, Ollama für günstige Calls, über `llm_overrides` konfigurierbar.",
  },
  {
    title: "Mode-Switch Simulation / Production",
    body: "Mock-DB für Demo & Dev, DataForSEO live für Produktion, kein Code-Change nötig.",
  },
  {
    title: "Variante-B: n8n-Wrapper → Python-Endpoint (ADR-012)",
    body: "Single-Source-of-Truth Python-Coord, n8n als HTTP-Proxy, 3× repliziert (cluster-full, strategy, reflect).",
  },
  {
    title: "Hybrid-Keyword-Generierung",
    body: "Anchor-Cluster als Skelett + parallele LLM-Variation pro Anker, 401 Keywords mit realistischer Long-Tail-Verteilung.",
  },
  {
    title: "Best-Practices als YAML-Bibliothek",
    body: "Deklarative Rules (z.B. `v2026_05.yaml`), versioniert, custom-Override möglich.",
  },
];

// ============================================================
// TAB 2 — AUGUR ARCHITEKTUR DATA
// ============================================================
const phase1Stages = [
  { name: "Research", desc: "Keywords via DataForSEO" },
  { name: "Embed", desc: "Vektoren, nomic-embed" },
  { name: "Cluster", desc: "Assign + LLM-Judge" },
];
const phase2Stages = [
  { name: "Performance", desc: "Hypothesis-Testing + Rules" },
  { name: "Copy", desc: "Ad-Copy je Cluster" },
  { name: "Synthese", desc: "Empfehlungs-Erzeugung" },
  { name: "Reflect", desc: "Selbstprüfung" },
];
const archTraits = [
  {
    title: "Deterministisch wo regelbar",
    desc: "Die Action kommt aus dem Regelwerk, nicht aus dem LLM. Das Modell ist Rationale-Schreiber, nicht Entscheider.",
  },
  {
    title: "Mode-Switch Simulation ↔ Production",
    desc: "Mock-DB für 0-€-Demos via Replay-Cache, DataForSEO live für Produktion. Umschaltung ohne Code-Change, Default ist Simulation.",
  },
  {
    title: "Faktencheck als Korrektheits-Anker",
    desc: "Ein Evidence-Validator prüft jede LLM-Zahl gegen die DB. Er deckte auf, wo das Modell Kausalität halluzinierte, und setzte den Reasoning-Proof auf ein ehrliches FAIL statt einen geschönten Pass.",
  },
];
const stackChips = [
  "LangGraph",
  "n8n",
  "FastAPI",
  "Pydantic v2",
  "PostgreSQL + pgvector",
  "Streamlit",
  "Docker",
];
const modelChips: { label: string; opt: boolean }[] = [
  { label: "qwen2.5:7b · Default", opt: false },
  { label: "nomic-embed", opt: false },
  { label: "Sonnet · opt-in reasoning", opt: true },
];
---

<SubPageLayout
  title="sem-agentic · Karsten Uhlig"
  description="Bei Agentic AI war Wissen nie der Engpass, sondern die Umsetzung. Ein eigener Engineering-Prototyp als praktischer Beleg."
>
  <!-- ============================ SCOPE-STECKBRIEF (Workflow rechts oben im Header) ============================ -->
  <ScopeSteckbrief
    eyebrow="Agentic AI · Marketing"
    title="sem-agentic"
    titleAs="h1"
    thesis="Wie weit lässt sich ein agentisches System mit sauberer Architektur, Validierung und Rollout-Logik bringen, am Anwendungsfall Google SEM."
    felder={scopeFelder}
    geltungsbereich={scopeGeltung}
  >
    <AugurWorkflowSchaubild slot="visual" />
  </ScopeSteckbrief>

  <!-- ============================ TABS ============================ -->
  <nav class="tabs" role="tablist" aria-label="sem-agentic Detail-Tabs">
    <button
      class="tab tab-active"
      data-tab="dashboard"
      role="tab"
      aria-selected="true"
      type="button"
    >
      1 · Dashboard
    </button>
    <button
      class="tab"
      data-tab="reflexionen"
      role="tab"
      aria-selected="false"
      type="button"
    >
      2 · Reflexionen
    </button>
    <button
      class="tab"
      data-tab="working-map"
      role="tab"
      aria-selected="false"
      type="button"
    >
      3 · Working Map
    </button>
    <button
      class="tab"
      data-tab="architektur"
      role="tab"
      aria-selected="false"
      type="button"
    >
      4 · Architektur
    </button>
    <button
      class="tab"
      data-tab="proof-of-concept"
      role="tab"
      aria-selected="false"
      type="button"
    >
      5 · Proof of Concept
    </button>
    <button
      class="tab"
      data-tab="blueprint"
      role="tab"
      aria-selected="false"
      type="button"
    >
      6 · Blueprint
    </button>
    <button
      class="tab"
      data-tab="erkenntnisse"
      role="tab"
      aria-selected="false"
      type="button"
    >
      7 · Erkenntnisse
    </button>
  </nav>

  <!-- ============================ TAB 1: DASHBOARD ============================ -->
  <section data-panel="dashboard" role="tabpanel">
    <div class="tab-sub">
      Augur Operator-Dashboard, die Streamlit-Oberfläche eines vollständigen
      Coordinator-Runs: KPI-Cards, Pipeline-Status, Recall-Verlauf, Critique-Ergebnisse
      und die priorisierten Cluster-Actions.
    </div>

    <figure class="dash-figure">
      <img
        src="/images/augur-dashboard.png"
        alt="Augur Operator-Dashboard mit KPI-Cards, Pipeline-Status, Recall-Verlauf, Critique-Ergebnissen und priorisierten Cluster-Actions"
        loading="lazy"
        decoding="async"
        width="650"
      />
    </figure>
  </section>

  <!-- ============================ TAB 2: REFLEXIONEN ============================ -->
  <section data-panel="reflexionen" role="tabpanel" hidden>
    <div class="refl-head">
      <div class="refl-eyebrow">Im Engineering gelernt</div>
      <h2 class="refl-h2">Sieben Patterns aus 2 Wochen Augur-Projekt.</h2>
      <p class="refl-lead">
        Pitfalls werden nicht vorab katalogisiert, sondern beim Engineering
        gesammelt. Pro Tag 30–60 Min Reflexion, verdichtet zu sieben
        übergreifenden Patterns. Jedes Pattern aus mindestens zwei
        unabhängigen Beobachtungen.
      </p>
    </div>

    <div class="refl-grid">
      <article class="refl-card">
        <div class="refl-num">01</div>
        <h3 class="refl-title">
          Architektur-Erosion durch<br />Werkzeug-Schwerkraft
        </h3>
        <p class="refl-body">
          Eine Architektur erodiert durch tausend Mikroentscheidungen, wenn
          sie nicht in jedem operativen Schritt aktiv durchgesetzt wird.
        </p>
      </article>

      <article class="refl-card">
        <div class="refl-num">02</div>
        <h3 class="refl-title">
          Senior-Aufmerksamkeit als<br />Schärfungs-Instrument
        </h3>
        <p class="refl-body">
          Senior-Sponsoren entscheiden nicht Inhalte, sondern stellen an den
          richtigen Stellen die richtige Frage.
        </p>
      </article>

      <article class="refl-card">
        <div class="refl-num">03</div>
        <h3 class="refl-title">
          Sprachliche Skizze ≠<br />operative Realität
        </h3>
        <p class="refl-body">
          Was im Plan klar klingt, ist im Team noch nicht definiert.
          Konkretion erzwingen, bevor Mehrarbeit beginnt.
        </p>
      </article>

      <article class="refl-card">
        <div class="refl-num">04</div>
        <h3 class="refl-title">
          Eval-Disziplin gegen<br />das eigene Wunschergebnis
        </h3>
        <p class="refl-body">
          Ohne harte Messgrößen entscheidet die letzte Output-Inspektion.
          Und die ist immer durch das eigene Wunschergebnis gefärbt.
        </p>
      </article>

      <article class="refl-card">
        <div class="refl-num">05</div>
        <h3 class="refl-title">Lernkultur statt Fehlerkultur</h3>
        <p class="refl-body">
          Eine Org lernt nicht durch Workshops, sondern durch dauerhafte
          Verankerung an der Stelle, wo die nächste Entscheidung fällt.
        </p>
      </article>

      <article class="refl-card">
        <div class="refl-num">06</div>
        <h3 class="refl-title">
          Pattern-Wiederverwendung<br />und Library-Effekt
        </h3>
        <p class="refl-body">
          Die wertvollste Investition ist nicht das nächste Tool, sondern
          eine Library aus internen Mustern, die als IP behandelt wird.
        </p>
      </article>

      <article class="refl-card">
        <div class="refl-num">07</div>
        <h3 class="refl-title">
          Operationalisierbarkeit und<br />Operator-Empathie
        </h3>
        <p class="refl-body">
          Marketing-AI scheitert nicht am Modell, sondern an der
          Bedienbarkeit für die Person, die es täglich nutzen muss.
        </p>
      </article>
    </div>

    <div class="refl-cta-row">
      <a
        href="/Augur_Reflexionen_Pitch.pdf"
        class="refl-cta"
        download="Augur_Reflexionen_Pitch.pdf"
      >
        <span class="refl-cta-icon" aria-hidden="true">⬇</span>
        Volle Präsentation als PDF
        <span class="refl-cta-meta">(15 Seiten)</span>
      </a>
    </div>
  </section>

  <!-- ============================ TAB 2: WORKING & PRODUCT MAP ============================ -->
  <section data-panel="working-map" role="tabpanel" hidden>
    <div class="tab-sub">
      Working &amp; Product Map, wie ich arbeite, was dabei entsteht und was
      es differenziert. Stand 01.06.2026.
    </div>

    <div class="map">
      <div class="map-grid">
        <!-- LINKS: Working Organization -->
        <div class="panel">
          <div class="panel-title">working organization</div>

          <div class="role-card">
            <div class="role-name">Karsten</div>
            <div class="role-sub">senior · approval · vp-story owner</div>
          </div>

          <div class="duo-grid">
            <div class="duo claude-chat">
              <div class="duo-title">claude chat</div>
              <div class="chip-stack">
                {claudeChatItems.map((s) => <div class="chip">{s}</div>)}
              </div>
            </div>
            <div class="duo claude-code">
              <div class="duo-title">claude code</div>
              <div class="chip-stack">
                {claudeCodeItems.map((s) => <div class="chip">{s}</div>)}
              </div>
            </div>
          </div>

          <div class="maturity">
            <div class="maturity-head">
              <div class="maturity-title">
                ai engineering practices · reifegrad
              </div>
              <div class="maturity-meta">
                re-audit v3 · stand 31.05.2026 · 38 / 90 · 42 % maturity (von
                33 %)
              </div>
            </div>

            <p class="maturity-note">Die niedrigen Felder sind kein Versäumnis, sondern eine Entscheidung: umgesetzt wurde, was den Punkt beweist, nicht was die Tabelle füllt. Ein ehrlicher Stand sagt mehr als ein geschönter.</p>

            <div class="maturity-legend">
              {
                maturityLegend.map((l) => (
                  <span class="legend-item">
                    <span
                      class="legend-box"
                      style={`background:${l.bg}; color:${l.fg};`}
                    >
                      {l.lvl}
                    </span>
                    {l.text}
                  </span>
                ))
              }
            </div>

            {
              pillars.map((p) => (
                <div class="pillar">
                  <div
                    class="pillar-head"
                    style={`border-left-color:${p.accent};`}
                  >
                    <span>
                      {p.letter} · {p.title}
                    </span>
                    <span class="pillar-score" style={`color:${p.accent};`}>
                      {p.score}
                    </span>
                  </div>
                  <div class="pillar-items">
                    {p.items.map((it) => {
                      const tone = maturityLegend[it.level];
                      return (
                        <div class="pillar-item">
                          <span>{it.name}</span>
                          <span
                            class="lvl-pill"
                            style={`background:${tone.bg}; color:${tone.fg};`}
                          >
                            {it.level}
                          </span>
                        </div>
                      );
                    })}
                  </div>
                </div>
              ))
            }
          </div>

          <div class="block">
            <div class="block-title">shared workspace · 15 ADRs</div>
            <div class="tag-row">
              {adrTags.map((t) => <span class="tag mono">{t}</span>)}
            </div>
          </div>

          <div class="block">
            <div class="block-title">tools &amp; plattformen</div>
            <div class="block-body">
              claude.ai · claude code · github · localhost:5678 · browser
            </div>
          </div>
        </div>

        <!-- RECHTS: Project sem-agentic / Augur -->
        <div class="panel">
          <div class="panel-title">project · sem-agentic / augur</div>

          <div class="duo claude-chat strategy-coord">
            <div class="duo-title-lg">Strategy Coordinator</div>
            <div class="duo-sub">
              langgraph · self-reflection iter≤2 · pol-c enforcement
            </div>
          </div>

          <div class="duo-grid">
            <div class="duo n8n-cat">
              <div class="duo-title">n8n workflows · 9</div>
              <div class="chip-stack">
                <div class="chip">research · embed · cluster-assign</div>
                <div class="chip">cluster-judge · perf-data-gen</div>
                <div class="chip">performance-analyst</div>
                <div class="chip chip-dashed">
                  cluster-full · strategy-pipeline · reflect (variante-b)
                </div>
              </div>
            </div>
            <div class="duo python-cat">
              <div class="duo-title">python services · 10</div>
              <div class="chip-stack">
                <div class="chip">performance analyst · copy agent</div>
                <div class="chip">strategy coordinator · fastapi</div>
                <div class="chip">critique-rules · action-thresholds</div>
                <div class="chip chip-dashed">
                  performance-eval · rule-compliance-eval (two-track)
                </div>
              </div>
            </div>
          </div>

          <div class="duo-grid">
            <div class="duo claude-code">
              <div class="duo-title">augur ui · 6 tabs</div>
              <div class="chip-stack">
                <div class="chip">übersicht · workflows · daten</div>
                <div class="chip">letzter run · runs · coordinator</div>
                <div class="chip">kpi-cards · pipeline-viz · charts</div>
                <div class="chip">aggrid-tables · run-diff · drill-down</div>
              </div>
            </div>
            <div class="duo container-cat">
              <div class="duo-title">containerization</div>
              <div class="chip-stack">
                <div class="chip">docker compose</div>
                <div class="chip">ollama container</div>
                <div class="chip">n8n container</div>
                <div class="chip">postgres + pgvector</div>
                <div class="chip">volume persistence</div>
              </div>
            </div>
          </div>

          <div class="block">
            <div class="block-title">scale &amp; tests</div>
            <div class="block-body">
              401 keywords · 16 anchor-cluster · 236 tests · 15 ADRs ·
              90-Tage-Perf-Daten
            </div>
          </div>
          <div class="block">
            <div class="block-title">frameworks</div>
            <div class="block-body">
              langgraph · langchain · pydantic v2 · scipy · fastapi · streamlit
              + aggrid
            </div>
          </div>
          <div class="block">
            <div class="block-title">llms</div>
            <div class="block-body">
              anthropic sonnet 4.5 · ollama qwen2.5:7b · ollama nomic-embed
            </div>
          </div>
          <div class="block">
            <div class="block-title">daten &amp; externe</div>
            <div class="block-body">
              postgresql + pgvector · filesystem cache · dataforseo api
            </div>
          </div>
        </div>
      </div>
    </div>

    <section class="features">
      <div class="features-eyebrow">
        Product Besonderheiten: was es differenziert
      </div>
      <div class="features-grid">
        {
          features.map((f) => (
            <div class="feature">
              <div class="feature-title">{f.title}</div>
              <div
                class="feature-body"
                set:html={f.body.replace(/`([^`]+)`/g, "<code>$1</code>")}
              />
            </div>
          ))
        }
      </div>
      <div class="features-source">
        Quellen: 15 ADRs · Reflections · status.md · Code-Patterns · audit.md ·
        Maturity-v3
      </div>
    </section>
  </section>

  <!-- ============================ TAB 2: ARCHITEKTUR (Multi-Agent) ============================ -->
  <section data-panel="architektur" role="tabpanel" hidden>
    <div class="arc-top">
      <div class="arc-header">
        <div class="arc-eyebrow">
          <span class="arc-live-dot" aria-hidden="true"></span>Augur · Architektur
        </div>
        <h2 class="arc-h1">Multi-Agent-System mit gestufter Validierung</h2>
        <p class="arc-subtitle">
          Fünf spezialisierte Agenten produzieren Vorschläge mit Begründung.
          Jeder Agent durchläuft eine Validierungs-Schicht, die zu seiner
          Ergebnisart passt. Der Strategy-Coordinator verdichtet die Ergebnisse
          mit Selbstprüfung zu einer auditfähigen Empfehlung.
        </p>
      </div>
      <div class="arc-mode-switch" aria-hidden="true">
        Mode
        <span class="arc-mode-toggle">
          <span class="arc-active">Sim</span>
          <span>Prod</span>
        </span>
      </div>
    </div>

    <!-- INPUT -->
    <div class="arc-input-row">
      <div class="arc-input-box">
        Brief <strong>NordicGlow Skincare D2C, DACH-Markteintritt</strong>
      </div>
    </div>
    <div class="arc-down-arrow" aria-hidden="true">↓</div>

    <!-- AGENT GRID -->
    <div class="arc-agent-grid">
