---
import SubPageLayout from "../../layouts/SubPageLayout.astro";
import PageHeader from "../../components/PageHeader.astro";

// ============================================================
// TAB 1 — WORKING & PRODUCT MAP DATA
// ============================================================
const claudeChatItems = [
  "Strategy & Sparring",
  "VP-Story Material",
  "Reflection & Memory",
  "Documents & Visuals",
];
const claudeCodeItems = [
  "Code-Stand prüfen",
  "Architektur-Skizze",
  "Services bauen",
  "ADRs & Tests",
];

const maturityLegend = [
  { lvl: "0", text: "not present", bg: "#D3D1C7", fg: "#2C2C2A" },
  { lvl: "1", text: "aware", bg: "#F5C4B3", fg: "#4A1B0C" },
  { lvl: "2", text: "repeatable", bg: "#FAC775", fg: "#412402" },
  { lvl: "3", text: "defined", bg: "#C0DD97", fg: "#173404" },
  { lvl: "4", text: "managed", bg: "#97C459", fg: "#173404" },
  { lvl: "5", text: "optim.", bg: "#639922", fg: "#FFFFFF" },
];

type Pillar = {
  letter: string;
  title: string;
  score: string;
  accent: string;
  items: { name: string; level: 0 | 1 | 2 | 3 | 4 | 5 }[];
};

const pillars: Pillar[] = [
  {
    letter: "A",
    title: "engineering discipline",
    score: "15/20",
    accent: "#534AB7",
    items: [
      { name: "stage-1/2 build", level: 3 },
      { name: "pre-flight audit", level: 4 },
      { name: "discrepancy-driven", level: 4 },
      { name: "hard-fail senior", level: 4 },
    ],
  },
  {
    letter: "B",
    title: "knowledge & workspace",
    score: "16/30",
    accent: "#378ADD",
    items: [
      { name: "cross-chat memory", level: 2 },
      { name: "conversation recall", level: 2 },
      { name: "audit + re-audit", level: 3 },
      { name: "reusable prompts", level: 3 },
      { name: "shared workspace", level: 4 },
      { name: "tiered knowledge", level: 3 },
    ],
  },
  {
    letter: "C",
    title: "agentic system architecture",
    score: "2/20",
    accent: "#BA7517",
    items: [
      { name: "skills-system", level: 1 },
      { name: "goal-setter", level: 1 },
      { name: "background-routines", level: 0 },
      { name: "mcp-integration", level: 0 },
    ],
  },
  {
    letter: "D",
    title: "quality & observability",
    score: "5/20",
    accent: "#1D9E75",
    items: [
      { name: "eval-driven ci", level: 2 },
      { name: "observability+cost", level: 2 },
      { name: "a/b prompt-testing", level: 0 },
      { name: "self-maintenance", level: 1 },
    ],
  },
];

const adrTags = [
  "project.md",
  "status.md",
  "adrs/ ·15",
  "reflections/",
  "audit.md",
  "backlog.md",
];

const features = [
  {
    title: "Zwei-Schichten-Architektur (ADR-015)",
    body: "Deterministische Action-Schicht (Pre-flight Rules) + optionale LLM-Analyst-Schicht — Schicht 2 unter Beweisvorbehalt, nicht gebaut bis Mehrwert belegt.",
  },
  {
    title: "Two-Track Eval (ADR-013)",
    body: "F1 vs Domain-Ground-Truth + Rule-Compliance orthogonal — belegt: LLM hält 6% der Constraints von selbst, Deterministik rettet 94%.",
  },
  {
    title: "Cluster-Aggregation gegen Prompt-Kollaps (ADR-014)",
    body: "626 Keyword-Forced-Recs → 17 Cluster-Forderungen, Prompt 33k→3-4k Tokens — 0 Determinismus-Violations über N Läufe.",
  },
  {
    title: "LLM-Backend pro Step wählbar",
    body: "Sonnet für Reasoning, Ollama für günstige Calls — über `llm_overrides` konfigurierbar.",
  },
  {
    title: "Mode-Switch Simulation / Production",
    body: "Mock-DB für Demo & Dev, DataForSEO live für Produktion — kein Code-Change nötig.",
  },
  {
    title: "Variante-B: n8n-Wrapper → Python-Endpoint (ADR-012)",
    body: "Single-Source-of-Truth Python-Coord, n8n als HTTP-Proxy — 3× repliziert (cluster-full, strategy, reflect).",
  },
  {
    title: "Hybrid-Keyword-Generierung",
    body: "Anchor-Cluster als Skelett + parallele LLM-Variation pro Anker — 401 Keywords mit realistischer Long-Tail-Verteilung.",
  },
  {
    title: "Best-Practices als YAML-Bibliothek",
    body: "Deklarative Rules (z.B. `v2026_05.yaml`), versioniert, custom-Override möglich.",
  },
];

// ============================================================
// TAB 2 — AUGUR ARCHITEKTUR DATA
// ============================================================
const phase1Stages = [
  { name: "Research", desc: "Keywords via DataForSEO" },
  { name: "Embed", desc: "Vektoren, nomic-embed" },
  { name: "Cluster", desc: "Assign + LLM-Judge" },
];
const phase2Stages = [
  { name: "Performance", desc: "Hypothesis-Testing + Rules" },
  { name: "Copy", desc: "Ad-Copy je Cluster" },
  { name: "Synthese", desc: "Empfehlungs-Erzeugung" },
  { name: "Reflect", desc: "Self-Critique" },
];
const archTraits = [
  {
    title: "Deterministisch wo regelbar",
    desc: "Die Action kommt aus dem Regelwerk, nicht aus dem LLM. Das Modell ist Rationale-Schreiber, nicht Entscheider.",
  },
  {
    title: "Mode-Switch Simulation ↔ Production",
    desc: "Mock-DB für 0-€-Demos via Replay-Cache, DataForSEO live für Produktion. Umschaltung ohne Code-Change, Default ist Simulation.",
  },
  {
    title: "Faktencheck als Korrektheits-Anker",
    desc: "Ein Evidence-Validator prüft jede LLM-Zahl gegen die DB. Er deckte auf, wo das Modell Kausalität halluzinierte — und setzte den Reasoning-Proof auf ein ehrliches FAIL statt einen geschönten Pass.",
  },
];
const stackChips = [
  "LangGraph",
  "n8n",
  "FastAPI",
  "Pydantic v2",
  "PostgreSQL + pgvector",
  "Streamlit",
  "Docker",
];
const modelChips: { label: string; opt: boolean }[] = [
  { label: "qwen2.5:7b · Default", opt: false },
  { label: "nomic-embed", opt: false },
  { label: "Sonnet · opt-in reasoning", opt: true },
];
---

<SubPageLayout
  title="sem-agentic — Karsten Uhlig"
  description="Agentic AI System für SEM-Performance: Working Map und Architektur."
>
  <PageHeader
    eyebrow="Feasibility Study"
    headline="sem-agentic"
    intro="Agentic AI System für SEM-Performance. Working Map und Architektur."
  />

  <!-- ============================ TABS ============================ -->
  <nav class="tabs" role="tablist" aria-label="sem-agentic Detail-Tabs">
    <button
      class="tab tab-active"
      data-tab="working-map"
      role="tab"
      aria-selected="true"
      type="button"
    >
      1 · Working Map
    </button>
    <button
      class="tab"
      data-tab="architektur"
      role="tab"
      aria-selected="false"
      type="button"
    >
      2 · Architektur
    </button>
  </nav>

  <!-- ============================ TAB 1: WORKING & PRODUCT MAP ============================ -->
  <section data-panel="working-map" role="tabpanel">
    <div class="tab-sub">
      Working &amp; Product Map — wie ich arbeite, was dabei entsteht und was
      es differenziert. Stand 01.06.2026.
    </div>

    <div class="map">
      <div class="map-grid">
        <!-- LINKS: Working Organization -->
        <div class="panel">
          <div class="panel-title">working organization</div>

          <div class="role-card">
            <div class="role-name">Karsten</div>
            <div class="role-sub">senior · approval · vp-story owner</div>
          </div>

          <div class="duo-grid">
            <div class="duo claude-chat">
              <div class="duo-title">claude chat</div>
              <div class="chip-stack">
                {claudeChatItems.map((s) => <div class="chip">{s}</div>)}
              </div>
            </div>
            <div class="duo claude-code">
              <div class="duo-title">claude code</div>
              <div class="chip-stack">
                {claudeCodeItems.map((s) => <div class="chip">{s}</div>)}
              </div>
            </div>
          </div>

          <div class="maturity">
            <div class="maturity-head">
              <div class="maturity-title">
                ai engineering practices · reifegrad
              </div>
              <div class="maturity-meta">
                re-audit v3 · stand 31.05.2026 · 38 / 90 · 42 % maturity (von
                33 %)
              </div>
            </div>

            <div class="maturity-legend">
              {
                maturityLegend.map((l) => (
                  <span class="legend-item">
                    <span
                      class="legend-box"
                      style={`background:${l.bg}; color:${l.fg};`}
                    >
                      {l.lvl}
                    </span>
                    {l.text}
                  </span>
                ))
              }
            </div>

            {
              pillars.map((p) => (
                <div class="pillar">
                  <div
                    class="pillar-head"
                    style={`border-left-color:${p.accent};`}
                  >
                    <span>
                      {p.letter} · {p.title}
                    </span>
                    <span class="pillar-score" style={`color:${p.accent};`}>
                      {p.score}
                    </span>
                  </div>
                  <div class="pillar-items">
                    {p.items.map((it) => {
                      const tone = maturityLegend[it.level];
                      return (
                        <div class="pillar-item">
                          <span>{it.name}</span>
                          <span
                            class="lvl-pill"
                            style={`background:${tone.bg}; color:${tone.fg};`}
                          >
                            {it.level}
                          </span>
                        </div>
                      );
                    })}
                  </div>
                </div>
              ))
            }
          </div>

          <div class="block">
            <div class="block-title">shared workspace · 15 ADRs</div>
            <div class="tag-row">
              {adrTags.map((t) => <span class="tag mono">{t}</span>)}
            </div>
          </div>

          <div class="block">
            <div class="block-title">tools &amp; plattformen</div>
            <div class="block-body">
              claude.ai · claude code · github · localhost:5678 · browser
            </div>
          </div>
        </div>

        <!-- RECHTS: Project sem-agentic / Augur -->
        <div class="panel">
          <div class="panel-title">project · sem-agentic / augur</div>

          <div class="duo claude-chat strategy-coord">
            <div class="duo-title-lg">Strategy Coordinator</div>
            <div class="duo-sub">
              langgraph · self-reflection iter≤2 · pol-c enforcement
            </div>
          </div>

          <div class="duo-grid">
            <div class="duo n8n-cat">
              <div class="duo-title">n8n workflows · 9</div>
              <div class="chip-stack">
                <div class="chip">research · embed · cluster-assign</div>
                <div class="chip">cluster-judge · perf-data-gen</div>
                <div class="chip">performance-analyst</div>
                <div class="chip chip-dashed">
                  cluster-full · strategy-pipeline · reflect (variante-b)
                </div>
              </div>
            </div>
            <div class="duo python-cat">
              <div class="duo-title">python services · 10</div>
              <div class="chip-stack">
                <div class="chip">performance analyst · copy agent</div>
                <div class="chip">strategy coordinator · fastapi</div>
                <div class="chip">critique-rules · action-thresholds</div>
                <div class="chip chip-dashed">
                  performance-eval · rule-compliance-eval (two-track)
                </div>
              </div>
            </div>
          </div>

          <div class="duo-grid">
            <div class="duo claude-code">
              <div class="duo-title">augur ui · 6 tabs</div>
              <div class="chip-stack">
                <div class="chip">übersicht · workflows · daten</div>
                <div class="chip">letzter run · runs · coordinator</div>
                <div class="chip">kpi-cards · pipeline-viz · charts</div>
                <div class="chip">aggrid-tables · run-diff · drill-down</div>
              </div>
            </div>
            <div class="duo container-cat">
              <div class="duo-title">containerization</div>
              <div class="chip-stack">
                <div class="chip">docker compose</div>
                <div class="chip">ollama container</div>
                <div class="chip">n8n container</div>
                <div class="chip">postgres + pgvector</div>
                <div class="chip">volume persistence</div>
              </div>
            </div>
          </div>

          <div class="block">
            <div class="block-title">scale &amp; tests</div>
            <div class="block-body">
              401 keywords · 16 anchor-cluster · 236 tests · 15 ADRs ·
              90-Tage-Perf-Daten
            </div>
          </div>
          <div class="block">
            <div class="block-title">frameworks</div>
            <div class="block-body">
              langgraph · langchain · pydantic v2 · scipy · fastapi · streamlit
              + aggrid
            </div>
          </div>
          <div class="block">
            <div class="block-title">llms</div>
            <div class="block-body">
              anthropic sonnet 4.5 · ollama qwen2.5:7b · ollama nomic-embed
            </div>
          </div>
          <div class="block">
            <div class="block-title">daten &amp; externe</div>
            <div class="block-body">
              postgresql + pgvector · filesystem cache · dataforseo api
            </div>
          </div>
        </div>
      </div>
    </div>

    <section class="features">
      <div class="features-eyebrow">
        Product Besonderheiten — was es differenziert
      </div>
      <div class="features-grid">
        {
          features.map((f) => (
            <div class="feature">
              <div class="feature-title">{f.title}</div>
              <div
                class="feature-body"
                set:html={f.body.replace(/`([^`]+)`/g, "<code>$1</code>")}
              />
            </div>
          ))
        }
      </div>
      <div class="features-source">
        Quellen: 15 ADRs · Reflections · status.md · Code-Patterns · audit.md ·
        Maturity-v3
      </div>
    </section>
  </section>

  <!-- ============================ TAB 2: ARCHITEKTUR ============================ -->
  <section data-panel="architektur" role="tabpanel" hidden>
    <div class="aug-head">
      <div class="aug-kicker">sem-agentic · architektur-beweis</div>
      <h2 class="aug-h1">Augur</h2>
      <div class="aug-sub">
        Ein Multi-Agent-System für SEM-Performance. Deterministisch, wo die
        Regeln klar sind — LLM nur, wo es Mehrwert bringt.
      </div>
    </div>

    <div class="aug-flow">
      <!-- Input -->
      <div class="aug-io">
        <div class="aug-io-t">Brand-Briefing + Keyword-Set</div>
        <div class="aug-io-s">Eingang eines vollständigen Coordinator-Runs</div>
      </div>
      <div class="aug-varr" aria-hidden="true">↓</div>

      <!-- Phase 1 -->
      <div class="aug-band">
        <div class="aug-phase-label">
          Beschaffung &amp; Clustering
          <span class="aug-tech">n8n · Ollama · pgvector</span>
        </div>
        <div class="aug-stages">
          {
            phase1Stages.map((s, i) => (
              <>
                {i > 0 && (
                  <div class="aug-arr" aria-hidden="true">
                    →
                  </div>
                )}
                <div class="aug-stage">
                  <div class="aug-s-n">{s.name}</div>
                  <div class="aug-s-d">{s.desc}</div>
                </div>
              </>
            ))
          }
        </div>
      </div>
      <div class="aug-varr" aria-hidden="true">↓</div>

      <!-- Phase 2 -->
      <div class="aug-band">
        <div class="aug-phase-label">
          Analyse &amp; Strategie
          <span class="aug-tech">LangGraph-Coordinator · Python</span>
        </div>
        <div class="aug-stages">
          {
            phase2Stages.map((s, i) => (
              <>
                {i > 0 && (
                  <div class="aug-arr" aria-hidden="true">
                    →
                  </div>
                )}
                <div class="aug-stage">
                  <div class="aug-s-n">{s.name}</div>
                  <div class="aug-s-d">{s.desc}</div>
                </div>
              </>
            ))
          }
        </div>
        <div class="aug-loop">
          ↺ Refine-Loop bei ungelösten Issues · max. 2 Iterationen
        </div>
      </div>

      <!-- Architecture core -->
      <div class="aug-core">
        <div class="aug-core-head">
          <div class="aug-ct">Das Herzstück: die Empfehlungs-Erzeugung</div>
          <div class="aug-cs">
            Hier verläuft die Architektur-Grenze — nicht zwischen Komponenten,
            sondern innerhalb der Entscheidung.
          </div>
        </div>
        <div class="aug-core-grid">
          <div class="aug-layer aug-layer-1">
            <div class="aug-l-tag">Schicht 1 · deterministisch</div>
            <div class="aug-l-h">Pre-flight-Rules → forcierte Actions</div>
            <div class="aug-l-b">
              Versioniertes Best-Practice-Regelwerk wertet den Daten-Snapshot
              aus und erzwingt die Cluster-Action. Auditierbar, reproduzierbar,
              kein Modell beteiligt.
            </div>
            <span class="aug-l-status">gebaut · aktiv</span>
          </div>
          <div class="aug-split-num">
            <div class="aug-big">94 %</div>
            <div class="aug-big-l">
              der System-Regeln<br />deterministisch gesichert
            </div>
            <div class="aug-vs">— vs —</div>
            <div class="aug-small">6 %</div>
            <div class="aug-small-l">
              hält das 7B-Modell<br />von sich aus ein
            </div>
          </div>
          <div class="aug-layer aug-layer-2">
            <div class="aug-l-tag">Schicht 2 · LLM-reasoning</div>
            <div class="aug-l-h">Priorisierung &amp; Cross-Cluster-Narrative</div>
            <div class="aug-l-b">
              Soll Urteilsvermögen beitragen, wo keine Regel greift. Heute nur
              Rationale-Beitrag — eigenständiges Reasoning steht unter
              Beweisvorbehalt.
            </div>
            <span class="aug-l-status">Richtung entschieden · nicht gebaut</span>
          </div>
        </div>
      </div>

      <div class="aug-varr" aria-hidden="true">↓</div>

      <!-- Output -->
      <div class="aug-io">
        <div class="aug-io-t">Priorisierte Cluster-Actions</div>
        <div class="aug-io-s">
          Scale · Maintain · Investigate · Pause — mit Rationale, Confidence,
          Impact &amp; voller Lineage
        </div>
      </div>

      <!-- Footer cards -->
      <div class="aug-foot">
        <div class="aug-foot-card">
          <div class="aug-fc-t">Was die Architektur differenziert</div>
          {
            archTraits.map((t) => (
              <div class="aug-trait">
                <div class="aug-tr-h">{t.title}</div>
                <div class="aug-tr-d">{t.desc}</div>
              </div>
            ))
          }
        </div>
        <div class="aug-foot-card">
          <div class="aug-fc-t">Stack</div>
          <div class="aug-fc-b chip-area">
            {stackChips.map((c) => <span class="aug-chip">{c}</span>)}
          </div>
          <div class="aug-fc-t" style="margin-top:0.7rem;">Modelle</div>
          <div class="aug-fc-b chip-area">
            {
              modelChips.map((m) => (
                <span class={`aug-chip ${m.opt ? "aug-chip-opt" : ""}`}>
                  {m.label}
                </span>
              ))
            }
          </div>
        </div>
      </div>
    </div>

    <div class="aug-stamp">
      <span class="aug-dot" aria-hidden="true"></span>
      Verifizierter Architektur-Stand · 9 Workflows · 7 Coordinator-Stages · 17
      Cluster
    </div>
  </section>
</SubPageLayout>

<script is:inline>
  (function () {
    const tabs = document.querySelectorAll("[data-tab]");
    const panels = document.querySelectorAll("[data-panel]");

    function activate(name) {
      tabs.forEach(function (t) {
        const active = t.getAttribute("data-tab") === name;
        t.classList.toggle("tab-active", active);
        t.setAttribute("aria-selected", String(active));
      });
      panels.forEach(function (p) {
        p.hidden = p.getAttribute("data-panel") !== name;
      });
      if (history.replaceState) {
        history.replaceState(null, "", "#" + name);
      }
    }

    tabs.forEach(function (t) {
      t.addEventListener("click", function () {
        activate(t.getAttribute("data-tab"));
      });
    });

    const hash = (window.location.hash || "").slice(1);
    if (hash === "architektur" || hash === "working-map") {
      activate(hash);
    }
  })();
</script>

<style>
  /* ============================== TABS ============================== */
  .tabs {
    display: flex;
    gap: 0.25rem;
    border-bottom: 1px solid var(--color-border);
    margin: -0.5rem 0 2rem;
    flex-wrap: wrap;
  }
  .tab {
    border: none;
    background: transparent;
    padding: 0.75rem 1.25rem;
    font-family: inherit;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-ink-3);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition:
      color 0.2s ease,
      border-color 0.2s ease;
  }
  .tab:hover {
    color: var(--color-ink-2);
  }
  .tab-active {
    color: var(--color-ink);
    border-bottom-color: var(--color-amber);
  }
  .tab-sub {
