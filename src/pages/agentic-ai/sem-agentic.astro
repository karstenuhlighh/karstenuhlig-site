<!-- PDF.js viewer — Multi-Instance support, lazy-loaded via dynamic import.
     Jeder [data-pdf-id="..."] Container ist eine eigenständige Viewer-Instanz
     mit eigenem State (currentPage, currentScale, doc, renderTask).            -->
<script>
  type Lib = typeof import("pdfjs-dist");

  interface ViewerState {
    id: string;
    pdfUrl: string;
    container: HTMLElement;
    doc: import("pdfjs-dist").PDFDocumentProxy | null;
    currentPage: number;
    currentScale: number | "fit";
    renderTask: import("pdfjs-dist").RenderTask | null;
    initialised: boolean;
    canvas: HTMLCanvasElement;
    wrap: HTMLElement;
    pageEl: Element | null;
    pagesEl: Element | null;
    zoomEl: Element | null;
    statusEl: HTMLElement | null;
  }

  let pdfLib: Lib | null = null;
  const viewers = new Map<string, ViewerState>();

  async function ensurePdfLib(): Promise<Lib> {
    if (pdfLib) return pdfLib;
    const [lib, workerUrl] = await Promise.all([
      import("pdfjs-dist"),
      import("pdfjs-dist/build/pdf.worker.min.mjs?url"),
    ]);
    lib.GlobalWorkerOptions.workerSrc = workerUrl.default;
    pdfLib = lib;
    return lib;
  }

  function getViewer(container: HTMLElement): ViewerState | null {
    const id = container.dataset.pdfId;
    if (!id) return null;
    const cached = viewers.get(id);
    if (cached) return cached;
    const canvas = container.querySelector<HTMLCanvasElement>(
      "[data-pdf-canvas]",
    );
    const wrap = container.querySelector<HTMLElement>("[data-pdf-canvas-wrap]");
    if (!canvas || !wrap) return null;
    const state: ViewerState = {
      id,
      pdfUrl: container.dataset.pdfSrc || "",
      container,
      doc: null,
      currentPage: 1,
      currentScale: "fit",
      renderTask: null,
      initialised: false,
      canvas,
      wrap,
      pageEl: container.querySelector("[data-pdf-page]"),
      pagesEl: container.querySelector("[data-pdf-pages]"),
      zoomEl: container.querySelector("[data-pdf-zoom]"),
      statusEl: container.querySelector<HTMLElement>("[data-pdf-status]"),
    };
    viewers.set(id, state);
    return state;
  }

  function updateMeta(v: ViewerState) {
    if (v.pageEl) v.pageEl.textContent = String(v.currentPage);
    if (v.pagesEl) v.pagesEl.textContent = v.doc ? String(v.doc.numPages) : "—";
    if (v.zoomEl) {
      v.zoomEl.textContent =
        v.currentScale === "fit"
          ? "Fit"
          : Math.round((v.currentScale as number) * 100) + "%";
    }
  }

  async function renderPage(v: ViewerState, pageNum: number) {
    if (!v.doc) return;
    if (v.renderTask) {
      try {
        v.renderTask.cancel();
      } catch {}
      v.renderTask = null;
    }
    const page = await v.doc.getPage(pageNum);
    const containerWidth = Math.max(280, v.wrap.clientWidth - 16);
    const baseViewport = page.getViewport({ scale: 1 });
    const fitScale = containerWidth / baseViewport.width;
    const finalScale =
      v.currentScale === "fit" ? fitScale : (v.currentScale as number);
    const viewport = page.getViewport({ scale: finalScale });
    const dpr = window.devicePixelRatio || 1;
    v.canvas.width = Math.floor(viewport.width * dpr);
    v.canvas.height = Math.floor(viewport.height * dpr);
    v.canvas.style.width = viewport.width + "px";
    v.canvas.style.height = viewport.height + "px";
    const ctx = v.canvas.getContext("2d");
    if (!ctx) return;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    v.renderTask = page.render({ canvasContext: ctx, viewport });
    try {
      await v.renderTask.promise;
    } catch {
      // cancelled — fine
    }
    v.renderTask = null;
    updateMeta(v);
  }

  async function initViewer(v: ViewerState) {
    if (v.initialised) return;
    v.initialised = true;
    try {
      const lib = await ensurePdfLib();
      if (v.statusEl) v.statusEl.textContent = "Dokument wird gelesen…";
      const task = lib.getDocument({
        url: v.pdfUrl,
        cMapUrl: "https://unpkg.com/pdfjs-dist@6.0.227/cmaps/",
        cMapPacked: true,
      });
      v.doc = await task.promise;
      if (v.statusEl) v.statusEl.style.display = "none";
      v.currentScale = "fit";
      v.currentPage = 1;
      await renderPage(v, 1);
    } catch (e) {
      console.error(e);
      if (v.statusEl) {
        v.statusEl.textContent =
          "PDF konnte nicht geladen werden: " + (e as Error).message;
      }
      v.initialised = false;
    }
  }

  function bindControls() {
    document.querySelectorAll<HTMLElement>("[data-pdf-action]").forEach(
      function (btn) {
        btn.addEventListener("click", async function () {
          const container = btn.closest<HTMLElement>("[data-pdf-id]");
          if (!container) return;
          const v = getViewer(container);
          if (!v || !v.doc) return;
          const action = btn.dataset.pdfAction;
          if (action === "prev" && v.currentPage > 1) {
            v.currentPage--;
            await renderPage(v, v.currentPage);
          } else if (
            action === "next" &&
            v.doc &&
            v.currentPage < v.doc.numPages
          ) {
            v.currentPage++;
            await renderPage(v, v.currentPage);
          } else if (action === "zoom-in") {
            const base =
              v.currentScale === "fit" ? 1 : (v.currentScale as number);
            v.currentScale = Math.min(3, base + 0.25);
            await renderPage(v, v.currentPage);
          } else if (action === "zoom-out") {
            const base =
              v.currentScale === "fit" ? 1 : (v.currentScale as number);
            v.currentScale = Math.max(0.25, base - 0.25);
            await renderPage(v, v.currentPage);
          } else if (action === "zoom-fit") {
            v.currentScale = "fit";
            await renderPage(v, v.currentPage);
          }
        });
      },
    );
  }

  function maybeInitOnTab() {
    document.querySelectorAll<HTMLElement>("[data-pdf-id]").forEach(
      function (container) {
        const panel = container.closest<HTMLElement>("[data-panel]");
        if (!panel) return;
        const panelName = panel.getAttribute("data-panel");
        if (!panelName) return;
        const tab = document.querySelector<HTMLElement>(
          '[data-tab="' + panelName + '"]',
        );
        if (tab) {
          tab.addEventListener("click", function () {
            const v = getViewer(container);
            if (v && !v.initialised) initViewer(v);
          });
        }
        if (window.location.hash === "#" + panelName) {
          const v = getViewer(container);
          if (v) initViewer(v);
        }
      },
    );
  }

  // Re-render alle Viewer in fit mode bei Resize
  let resizeTimer: number | undefined;
  window.addEventListener("resize", function () {
    if (resizeTimer) window.clearTimeout(resizeTimer);
    resizeTimer = window.setTimeout(function () {
      viewers.forEach(function (v) {
        if (v.currentScale === "fit" && v.doc) {
