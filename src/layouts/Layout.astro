---
import "../styles/global.css";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "Karsten Uhlig | CDO & VP E-Commerce | Digital Commerce, MarTech, Agentic AI",
  description = "CDO & VP E-Commerce. Closing the gap between strategy and results: Digital Commerce, MarTech, Data & Agentic AI. Skalierte ein €1,6-Mrd.-Online-Geschäft bei der Otto Group.",
  ogImage = "/og-card.jpg",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const absoluteOgImage = new URL(ogImage, Astro.site).href;
const siteHome = new URL("/", Astro.site).href;

// Entity-SEO: Schema.org Person — die Sprache, die KI-Recherche-Tools (ChatGPT,
// Perplexity) und Recruiter-Sourcing lesen. Eine Person-Entity site-weit.
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Karsten Uhlig",
  jobTitle: [
    "Chief Digital Officer (CDO)",
    "VP E-Commerce & Growth",
    "VP Product & Technology",
  ],
  url: siteHome,
  image: absoluteOgImage,
  sameAs: ["https://www.linkedin.com/in/karsten-uhlig/"],
  alumniOf: { "@type": "Organization", name: "bonprix (Otto Group)" },
  knowsAbout: [
    "Digital Commerce",
    "E-Commerce",
    "Marketing Technology",
    "Data",
    "Agentic AI",
    "Digital Transformation",
    "Performance Marketing",
  ],
  description: description,
};
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph (LinkedIn / Facebook etc.) -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:locale" content="de_DE" />

    <!-- Twitter Card (nutzt og:* automatisch, hier nur Format-Hint) -->
    <meta name="twitter:card" content="summary_large_image" />

    <title>{title}</title>

    <!-- Entity-SEO: Schema.org Person (JSON-LD) -->
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  </head>
  <body>
    <slot />
    <Footer />
  </body>
</html>
